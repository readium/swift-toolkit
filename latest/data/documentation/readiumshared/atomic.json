{"abstract":[{"text":"Smart pointer protecting concurrent access to its memory to avoid data races.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@propertyWrapper","kind":"attribute"},{"text":" ","kind":"text"},{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Atomic","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Value","kind":"genericParameter"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"This is also a property wrapper, which makes it easy to use as:","type":"text"}],"type":"paragraph"},{"code":["@Atomic var data: Int"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"The property becomes read-only, to prevent a common error when modifying the property using its","type":"text"},{"text":" ","type":"text"},{"text":"previous value. For example:","type":"text"}],"type":"paragraph"},{"code":["data += 1"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This is not safe, because it’s actually two operations: a read and a write. The value might have changed"},{"type":"text","text":" "},{"type":"text","text":"between the moment you read it and when you write the result of incrementing the value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Instead, you must use "},{"type":"codeVoice","code":"write()"},{"type":"text","text":" to mutate the property:"}],"type":"paragraph"},{"code":["$data.write { value in","    value += 1","}"],"syntax":null,"type":"codeListing"}],"kind":"content"}],"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/Atomic\/init(wrappedValue:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","id