:"text"},{"text":"AccessibilityMetadataDisplayGuide","kind":"identifier"}],"title":"AccessibilityMetadataDisplayGuide","role":"symbol","identifier":"doc:\/\/Readium\/documentation\/ReadiumShared\/AccessibilityMetadataDisplayGuide","abstract":[{"text":"When presenting accessibility metadata provided by the publisher, it is","type":"text"},{"text":" ","type":"text"},{"text":"suggested that the section is introduced using terms such as “claims” or","type":"text"},{"text":" ","type":"text"},{"text":"“declarations” (e.g., “Accessibility Claims”).","type":"text"}],"type":"topic","navigatorTitle":[{"text":"AccessibilityMetadataDisplayGuide","kind":"identifier"}]},"doc://Readium/documentation/ReadiumShared/AccessibilityMetadataDisplayGuide/RichContent-swift.struct":{"role":"symbol","type":"topic","identifier":"doc:\/\/Readium\/documentation\/ReadiumShared\/AccessibilityMetadataDisplayGuide\/RichContent-swift.struct","title":"AccessibilityMetadataDisplayGuide.RichContent","url":"\/documentation\/readiumshared\/accessibilitymetadatadisplayguide\/richcontent-swift.struct","navigatorTitle":[{"kind":"identifier","text":"RichContent"}],"abstract":[{"type":"text","text":"Indicates the presence of math, chemical formulas, extended descriptions"},{"type":"text","text":" "},{"type":"text","text":"for information rich images, e.g., charts, diagrams, figures, graphs,"},{"type":"text","text":" "},{"type":"text","text":"and whether these are in an accessible format or available in an"},{"type":"text","text":" "},{"type":"text","text":"alternative form, e.g., whether math and chemical formulas are navigable"},{"type":"text","text":" "},{"type":"text","text":"with assistive technologies, or whether extended descriptions are"},{"type":"text","text":" "},{"type":"text","text":"available for information-rich images. In addition, it indicates the"},{"type":"text","text":" "},{"type":"text","text":"presence of videos and if closed captions, open captions, or transcripts"},{"type":"text","text":" "},{"type":"text","text":"for prerecorded audio are available."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RichContent"}]},"doc://Readium/documentation/ReadiumShared":{"kind":"symbol","url":"\/documentation\/readiumshared","type":"topic","identifier":"doc:\/\/Readium\/documentation\/ReadiumShared","abstract":[],"title":"ReadiumShared","role":"collection"}}}