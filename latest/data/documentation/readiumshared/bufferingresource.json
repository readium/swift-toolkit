{"abstract":[{"type":"text","text":"Wraps an existing "},{"type":"codeVoice","code":"Resource"},{"type":"text","text":" and buffers its content."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/init(resource:bufferSize:)-48h5z","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/init(resource:bufferSize:)-54cd7"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/sourceURL"],"generated":true,"title":"Instance Properties"},{"anchor":"Instance-Methods","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/estimatedLength()","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/properties()","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/stream(range:consume:)"],"generated":true,"title":"Instance Methods"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/Actor-Implementations","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/Closeable-Implementations","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/Loggable-Implementations","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/Resource-Implementations","doc:\/\/Readium\/documentation\/ReadiumShared\/BufferingResource\/Streamable-Implementations"],"generated":true,"title":"Default Implementations"}],"metadata":{"externalID":"s:13ReadiumShared17BufferingResourceC","role":"symbol","title":"BufferingResource","roleHeading":"Class","symbolKind":"class","fragments":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BufferingResource","kind":"identifier"}],"modules":[{"name":"ReadiumShared"}],"navigatorTitle":[{"text":"BufferingResource","kind":"identifier"}]},"identifier":{"