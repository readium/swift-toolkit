{"kind":"article","sections":[],"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Content","interfaceLanguage":"swift"},"metadata":{"role":"article","roleHeading":"Article","title":"Extracting the content of a publication"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"],"generated":true,"anchor":"Guides","title":"Guides"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"content":[{"type":"paragraph","inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"The described feature is still experimental and the implementation incomplete.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many high-level features require access to the raw content (text, media, etc.) of a publication, such as:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Text-to-speech","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Accessibility reader"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Basic search","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full-text search indexing"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Image or audio indexes"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ContentService"},{"type":"text","text":" provides a way to iterate through a publication’s content, extracted as semantic elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, request the publication’s "},{"type":"codeVoice","code":"Content"},{"type":"text","text":", starting from a given "},{"type":"codeVoice","code":"Locator"},{"type":"text","text":". If the locator is missing, the "},{"type":"codeVoice","code":"Content"},{"type":"text","text":" will be extracted from the beginning of the publication."}]},{"type":"codeListing","code":["guard let content = publication.content(from: startLocator) else {","    \/\/ Abort as the content cannot be extracted","    return","}"],"syntax":"swift"},{"anchor":"Extracting-the-raw-text-content","type":"heading","text":"Extracting the raw text content","level":2},{"type":"paragraph","inlineContent":[{"text":"Getting the whole raw text of a publication is such a common use case that a helper is available on ","type":"text"},{"type":"codeVoice","code":"Content"},{"text":":","type":"text"}]},{"type":"codeListing","code":["let wholeText = content.text()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This is an expensive operation, proceed with caution and cache the result if you need to reuse it.","type":"text"}]},{"anchor":"Iterating-through-the-content","type":"heading","text":"Iterating through the content","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The individual "},{"code":"Content","type":"codeVoice"},{"type":"text","text":" elements can be iterated through with a regular "},{"code":"for","type":"codeVoice"},{"type":"text","text":" loop by converting it to a sequence:"}]},{"type":"codeListing","code":["for element in content.sequence() {","    \/\/ Process element","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can get the whole list of elements with "},{"type":"codeVoice","code":"content.elements()"},{"type":"text","text":", or use the lower level APIs to iterate the content manually:"}]},{"type":"codeListing","code":["let iterator = content.iterator()","while let element = try iterator.next() {","    print(element)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some "},{"type":"codeVoice","code":"Content"},{"type":"text","text":" implementations support bidirectional iterations. To iterate backwards, use:"}]},{"type":"codeListing","code":["let iterator = content.iterator()","while let element = try iterator.previous() {","    print(element)","}"],"syntax":"swift"},{"anchor":"Processing-the-elements","type":"heading","text":"Processing the elements","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Content"},{"type":"text","text":" iterator yields "},{"type":"codeVoice","code":"ContentElement"},{"type":"text","text":" objects representing a single semantic portion of the publication, such as a heading, a paragraph or an embedded image."}]},{"type":"paragraph","inlineContent":[{"text":"Every element has a ","type":"text"},{"code":"locator","type":"codeVoice"},{"text":" property targeting it in the publication. You can use the locator, for example, to navigate to the element or to draw a ","type":"text"},{"code":"Decoration","type":"codeVoice"},{"text":" on top of it.","type":"text"}]},{"type":"codeListing","code":["navigator.go(to: element.locator)"],"syntax":"swift"},{"anchor":"Types-of-elements","type":"heading","text":"Types of elements","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the actual implementation of "},{"type":"codeVoice","code":"ContentElement"},{"type":"text","text":", more properties are available to access the actual data. The toolkit ships with a number of default implementations for common types of elements."}]},{"anchor":"Embedded-media","type":"heading","text":"Embedded media","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"EmbeddedContentElement","type":"codeVoice"},{"type":"text","text":" protocol is implemented by any element referencing an external resource. It contains an "},{"code":"embeddedLink","type":"codeVoice"},{"type":"text","text":" property you can use to get the actual content of the resource."}]},{"type":"codeListing","code":["if let element = element as? EmbeddedContentElement {","    let bytes = try publication","        .get(element.embeddedLink)","        .read().get()","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Here are the default available implementations:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"AudioContentElement","type":"codeVoice"},{"type":"text","text":" - audio clips"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"VideoContentElement","type":"codeVoice"},{"text":" - video clips","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"ImageContentElement"},{"type":"text","text":" - bitmap images, with the additional property:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"caption: String?"},{"text":" - figure caption, when available","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}]},{"anchor":"Text","type":"heading","text":"Text","level":4},{"anchor":"Textual-elements","type":"heading","text":"Textual elements","level":5},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"TextualContentElement","type":"codeVoice"},{"text":" protocol is implemented by any element which can be represented as human-readable text. This is useful when you want to extract the text content of a publication without caring for each individual type of elements.","type":"text"}]},{"type":"codeListing","code":["let wholeText = publication.content()","    .elements()","    .compactMap { ($0 as? TextualContentElement)?.text.takeIf { !$0.isEmpty } }","    .joined(separator: \"\\n\")"],"syntax":"swift"},{"anchor":"Text-elements","type":"heading","text":"Text elements","level":5},{"type":"paragraph","inlineContent":[{"type":"text","text":"Actual text elements are instances of "},{"code":"TextContentElement","type":"codeVoice"},{"type":"text","text":", which represent a single block of text such as a heading, a paragraph or a list item. It is comprised of a "},{"code":"role","type":"codeVoice"},{"type":"text","text":" and a list of "},{"code":"segments","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"role","type":"codeVoice"},{"text":" is the nature of the text element in the document. For example a heading, body, footnote or a quote. It can be used to reconstruct part of the structure of the original document.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A text element is composed of individual segments with their own ","type":"text"},{"type":"codeVoice","code":"locator"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"attributes"},{"text":". They are useful to associate attributes with a portion of a text element. For example, given the HTML paragraph:","type":"text"}]},{"type":"codeListing","code":["<p>It is pronounced <span lang=\"fr\">croissant<\/span>.<\/p>"],"syntax":"html"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following "},{"code":"TextContentElement","type":"codeVoice"},{"type":"text","text":" will be produced:"}]},{"type":"codeListing","code":["TextContentElement(","    role: .body,","    segments: [","        TextContentElement.Segment(text: \"It is pronounced \"),","        TextContentElement.Segment(text: \"croissant\", attributes: [ContentAttribute(key: .language, value: \"fr\")]),","        TextContentElement.Segment(text: \".\")","    ]",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you are not interested in the segment attributes, you can also use ","type":"text"},{"type":"codeVoice","code":"element.text"},{"text":" to get the concatenated raw text.","type":"text"}]},{"anchor":"Element-attributes","type":"heading","text":"Element attributes","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All types of "},{"type":"codeVoice","code":"ContentElement"},{"type":"text","text":" can have associated attributes. Custom "},{"type":"codeVoice","code":"ContentService"},{"type":"text","text":" implementations can use this as an extensibility point."}]},{"anchor":"Use-cases","type":"heading","text":"Use cases","level":2},{"anchor":"An-index-of-all-images-embedded-in-the-publication","type":"heading","text":"An index of all images embedded in the publication","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example extracts all the embedded images in the publication and displays them in a SwiftUI list. Clicking on an image jumps to its location in the publication."}]},{"type":"codeListing","code":["struct ImageIndex: View {","    struct Item: Hashable {","        let locator: Locator","        let text: String?","        let image: UIImage","    }","","    let publication: Publication","    let navigator: Navigator","    @State private var items: [Item] = []","","    init(publication: Publication, navigator: Navigator) {","        self.publication = publication","        self.navigator = navigator","    }","","    var body: some View {","        ScrollView {","            LazyVStack {","                ForEach(items, id: \\.self) { item in","                    VStack() {","                        Image(uiImage: item.image)","                        Text(item.text ?? \"No caption\")","                    }","                    .onTapGesture {","                        navigator.go(to: item.locator)","                    }","                }","            }","        }","        .onAppear {","            items = publication.content()?","                .elements()","                .compactMap { element in","                    guard","                        let element = element as? ImageContentElement,","                        let image = try? publication.get(element.embeddedLink)","                            .read().map(UIImage.init).get()","                    else {","                        return nil","                    }","","                    return Item(","                        locator: element.locator,","                        text: element.caption ?? element.accessibilityLabel,","                        image: image","                    )","                }","                ?? []","        }","    }","}"],"syntax":"swift"},{"anchor":"References","type":"heading","text":"References","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/readium\/architecture\/pull\/177"}],"type":"paragraph"}]}]}]}],"references":{"https://www.edrlab.org/readium-lcp/":{"url":"https:\/\/www.edrlab.org\/readium-lcp\/","type":"link","titleInlineContent":[{"type":"text","text":"Readium LCP"}],"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","title":"Readium LCP"},"doc://Readium/documentation/Readium/Open-Publication":{"abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" and a ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","kind":"article","title":"Opening a publication","role":"article","url":"\/documentation\/readium\/open-publication"},"doc://Readium/documentation/Readium/NavigatorOverview":{"url":"\/documentation\/readium\/navigatoroverview","title":"Navigator Overview","kind":"article","type":"topic","abstract":[{"type":"text","text":"Learn about the architecture, configuration, and usage of the Readium Navigator."}],"role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview"},"doc://Readium/documentation/Readium":{"abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"identifier":"doc:\/\/Readium\/documentation\/Readium","title":"Readium","kind":"article","role":"collection","type":"topic","url":"\/documentation\/readium"},"doc://Readium/documentation/Readium/Migration-Guide":{"abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}],"url":"\/documentation\/readium\/migration-guide","role":"article","kind":"article","title":"Migration Guide","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","type":"topic"},"doc://Readium/documentation/Readium/TTS":{"title":"Text-to-speech","identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","kind":"article","abstract":[],"type":"topic","role":"article","url":"\/documentation\/readium\/tts"},"doc://Readium/documentation/Readium/Accessibility":{"title":"Accessibility","kind":"article","abstract":[{"type":"text","text":"Some publications declare their accessibility features and limitations as metadata which broadly mirror the "},{"identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","type":"reference","isActive":true},{"type":"text","text":" specification."}],"url":"\/documentation\/readium\/accessibility","type":"topic","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Accessibility"},"https://www.w3.org/TR/epub-a11y-11":{"type":"link","titleInlineContent":[{"type":"text","text":"EPUB Accessibility"}],"title":"EPUB Accessibility","url":"https:\/\/www.w3.org\/TR\/epub-a11y-11","identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11"},"https://github.com/readium/architecture/pull/177":{"type":"link","titleInlineContent":[{"type":"text","text":"Content Iterator proposal"}],"title":"Content Iterator proposal","url":"https:\/\/github.com\/readium\/architecture\/pull\/177","identifier":"https:\/\/github.com\/readium\/architecture\/pull\/177"},"doc://Readium/documentation/Readium/Readium-LCP":{"role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","url":"\/documentation\/readium\/readium-lcp","type":"topic","title":"Supporting Readium LCP","kind":"article","abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.edrlab.org\/readium-lcp\/"},{"text":" DRM.","type":"text"}]},"doc://Readium/documentation/Readium/Getting-Started":{"kind":"article","role":"article","type":"topic","url":"\/documentation\/readium\/getting-started","identifier":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started","title":"Getting started","abstract":[{"type":"text","text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics."}]}}}