{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"Extracting the content of a publication","roleHeading":"Article","role":"article"},"seeAlsoSections":[{"identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"],"title":"Guides","generated":true,"anchor":"Guides"}],"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Readium\/documentation\/Readium\/Content"},"sections":[],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!NOTE]"},{"type":"text","text":" "},{"type":"text","text":"The described feature is still experimental and the implementation incomplete."}]}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"text","text":"Many high-level features require access to the raw content (text, media, etc.) of a publication, such as:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Text-to-speech","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Accessibility reader"}]}]},{"content":[{"inlineContent":[{"text":"Basic search","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Full-text search indexing","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Image or audio indexes"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ContentService"},{"text":" provides a way to iterate through a publication’s content, extracted as semantic elements.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"First, request the publication’s ","type":"text"},{"type":"codeVoice","code":"Content"},{"text":", starting from a given ","type":"text"},{"type":"codeVoice","code":"Locator"},{"text":". If the locator is missing, the ","type":"text"},{"type":"codeVoice","code":"Content"},{"text":" will be extracted from the beginning of the publication.","type":"text"}],"type":"paragraph"},{"code":["guard let content = publication.content(from: startLocator) else {","    \/\/ Abort as the content cannot be extracted","    return","}"],"type":"codeListing","syntax":"swift"},{"text":"Extracting the raw text content","level":2,"type":"heading","anchor":"Extracting-the-raw-text-content"},{"inlineContent":[{"type":"text","text":"Getting the whole raw text of a publication is such a common use case that a helper is available on "},{"type":"codeVoice","code":"Content"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let wholeText = content.text()"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This is an expensive operation, proceed with caution and cache the result if you need to reuse it.","type":"text"}],"type":"paragraph"},{"text":"Iterating through the content","level":2,"type":"heading","anchor":"Iterating-through-the-content"},{"inlineContent":[{"type":"text","text":"The individual "},{"code":"Content","type":"codeVoice"},{"type":"text","text":" elements can be iterated through with a regular "},{"code":"for","type":"codeVoice"},{"type":"text","text":" loop by converting it to a sequence:"}],"type":"paragraph"},{"code":["for element in content.sequence() {","    \/\/ Process element","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Alternatively, you can get the whole list of elements with ","type":"text"},{"code":"content.elements()","type":"codeVoice"},{"text":", or use the lower level APIs to iterate the content manually:","type":"text"}],"type":"paragraph"},{"code":["let iterator = content.iterator()","while let element = try iterator.next() {","    print(element)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Some "},{"type":"codeVoice","code":"Content"},{"type":"text","text":" implementations support bidirectional iterations. To iterate backwards, use:"}],"type":"paragraph"},{"code":["let iterator = content.iterator()","while let element = try iterator.previous() {","    print(element)","}"],"type":"codeListing","syntax":"swift"},{"text":"Processing the elements","level":2,"type":"heading","anchor":"Processing-the-elements"},{"inlineContent":[{"type":"text","text":"The "},{"code":"Content","type":"codeVoice"},{"type":"text","text":" iterator yields "},{"code":"ContentElement","type":"codeVoice"},{"type":"text","text":" objects representing a single semantic portion of the publication, such as a heading, a paragraph or an embedded image."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every element has a "},{"type":"codeVoice","code":"locator"},{"type":"text","text":" property targeting it in the publication. You can use the locator, for example, to navigate to the element or to draw a "},{"type":"codeVoice","code":"Decoration"},{"type":"text","text":" on top of it."}],"type":"paragraph"},{"code":["navigator.go(to: element.locator)"],"type":"codeListing","syntax":"swift"},{"text":"Types of elements","level":3,"type":"heading","anchor":"Types-of-elements"},{"inlineContent":[{"type":"text","text":"Depending on the actual implementation of "},{"type":"codeVoice","code":"ContentElement"},{"type":"text","text":", more properties are available to access the actual data. The toolkit ships with a number of default implementations for common types of elements."}],"type":"paragraph"},{"text":"Embedded media","level":4,"type":"heading","anchor":"Embedded-media"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"EmbeddedContentElement"},{"type":"text","text":" protocol is implemented by any element referencing an external resource. It contains an "},{"type":"codeVoice","code":"embeddedLink"},{"type":"text","text":" property you can use to get the actual content of the resource."}],"type":"paragraph"},{"code":["if let element = element as? EmbeddedContentElement {","    let bytes = try publication","        .get(element.embeddedLink)","        .read().get()","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Here are the default available implementations:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"AudioContentElement","type":"codeVoice"},{"text":" - audio clips","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"VideoContentElement","type":"codeVoice"},{"type":"text","text":" - video clips"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"ImageContentElement","type":"codeVoice"},{"type":"text","text":" - bitmap images, with the additional property:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"caption: String?","type":"codeVoice"},{"text":" - figure caption, when available","type":"text"}]}]}]}]}],"type":"unorderedList"},{"text":"Text","level":4,"type":"heading","anchor":"Text"},{"text":"Textual elements","level":5,"type":"heading","anchor":"Textual-elements"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"TextualContentElement"},{"type":"text","text":" protocol is implemented by any element which can be represented as human-readable text. This is useful when you want to extract the text content of a publication without caring for each individual type of elements."}],"type":"paragraph"},{"code":["let wholeText = publication.content()","    .elements()","    .compactMap { ($0 as? TextualContentElement)?.text.takeIf { !$0.isEmpty } }","    .joined(separator: \"\\n\")"],"type":"codeListing","syntax":"swift"},{"text":"Text elements","level":5,"type":"heading","anchor":"Text-elements"},{"inlineContent":[{"text":"Actual text elements are instances of ","type":"text"},{"code":"TextContentElement","type":"codeVoice"},{"text":", which represent a single block of text such as a heading, a paragraph or a list item. It is comprised of a ","type":"text"},{"code":"role","type":"codeVoice"},{"text":" and a list of ","type":"text"},{"code":"segments","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"role","type":"codeVoice"},{"text":" is the nature of the text element in the document. For example a heading, body, footnote or a quote. It can be used to reconstruct part of the structure of the original document.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A text element is composed of individual segments with their own ","type":"text"},{"code":"locator","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"attributes","type":"codeVoice"},{"text":". They are useful to associate attributes with a portion of a text element. For example, given the HTML paragraph:","type":"text"}],"type":"paragraph"},{"code":["<p>It is pronounced <span lang=\"fr\">croissant<\/span>.<\/p>"],"type":"codeListing","syntax":"html"},{"inlineContent":[{"text":"The following ","type":"text"},{"code":"TextContentElement","type":"codeVoice"},{"text":" will be produced:","type":"text"}],"type":"paragraph"},{"code":["TextContentElement(","    role: .body,","    segments: [","        TextContentElement.Segment(text: \"It is pronounced \"),","        TextContentElement.Segment(text: \"croissant\", attributes: [ContentAttribute(key: .language, value: \"fr\")]),","        TextContentElement.Segment(text: \".\")","    ]",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you are not interested in the segment attributes, you can also use "},{"type":"codeVoice","code":"element.text"},{"type":"text","text":" to get the concatenated raw text."}],"type":"paragraph"},{"text":"Element attributes","level":3,"type":"heading","anchor":"Element-attributes"},{"inlineContent":[{"text":"All types of ","type":"text"},{"code":"ContentElement","type":"codeVoice"},{"text":" can have associated attributes. Custom ","type":"text"},{"code":"ContentService","type":"codeVoice"},{"text":" implementations can use this as an extensibility point.","type":"text"}],"type":"paragraph"},{"text":"Use cases","level":2,"type":"heading","anchor":"Use-cases"},{"text":"An index of all images embedded in the publication","level":3,"type":"heading","anchor":"An-index-of-all-images-embedded-in-the-publication"},{"inlineContent":[{"type":"text","text":"This example extracts all the embedded images in the publication and displays them in a SwiftUI list. Clicking on an image jumps to its location in the publication."}],"type":"paragraph"},{"code":["struct ImageIndex: View {","    struct Item: Hashable {","        let locator: Locator","        let text: String?","        let image: UIImage","    }","","    let publication: Publication","    let navigator: Navigator","    @State private var items: [Item] = []","","    init(publication: Publication, navigator: Navigator) {","        self.publication = publication","        self.navigator = navigator","    }","","    var body: some View {","        ScrollView {","            LazyVStack {","                ForEach(items, id: \\.self) { item in","                    VStack() {","                        Image(uiImage: item.image)","                        Text(item.text ?? \"No caption\")","                    }","                    .onTapGesture {","                        navigator.go(to: item.locator)","                    }","                }","            }","        }","        .onAppear {","            items = publication.content()?","                .elements()","                .compactMap { element in","                    guard","                        let element = element as? ImageContentElement,","                        let image = try? publication.get(element.embeddedLink)","                            .read().map(UIImage.init).get()","                    else {","                        return nil","                    }","","                    return Item(","                        locator: element.locator,","                        text: element.caption ?? element.accessibilityLabel,","                        image: image","                    )","                }","                ?? []","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"References","level":2,"type":"heading","anchor":"References"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/readium\/architecture\/pull\/177","isActive":true,"type":"reference"}]}]}],"type":"unorderedList"}]}],"references":{"doc://Readium/documentation/Readium/Readium-LCP":{"url":"\/documentation\/readium\/readium-lcp","title":"Supporting Readium LCP","abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","type":"reference","isActive":true},{"text":" DRM.","type":"text"}],"kind":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","type":"topic","role":"article"},"doc://Readium/documentation/Readium":{"abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"role":"collection","title":"Readium","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium","url":"\/documentation\/readium","kind":"article"},"https://github.com/readium/architecture/pull/177":{"type":"link","title":"Content Iterator proposal","identifier":"https:\/\/github.com\/readium\/architecture\/pull\/177","titleInlineContent":[{"type":"text","text":"Content Iterator proposal"}],"url":"https:\/\/github.com\/readium\/architecture\/pull\/177"},"doc://Readium/documentation/Readium/TTS":{"abstract":[],"type":"topic","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","url":"\/documentation\/readium\/tts","title":"Text-to-speech","kind":"article"},"doc://Readium/documentation/Readium/Accessibility":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Accessibility","url":"\/documentation\/readium\/accessibility","title":"Accessibility","type":"topic","role":"article","abstract":[{"type":"text","text":"Some publications declare their accessibility features and limitations as metadata which broadly mirror the "},{"type":"reference","isActive":true,"identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11"},{"type":"text","text":" specification."}],"kind":"article"},"doc://Readium/documentation/Readium/Open-Publication":{"abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"type":"codeVoice","code":"AssetRetriever"},{"text":" and a ","type":"text"},{"type":"codeVoice","code":"PublicationOpener"},{"text":".","type":"text"}],"kind":"article","type":"topic","title":"Opening a publication","identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","url":"\/documentation\/readium\/open-publication","role":"article"},"doc://Readium/documentation/Readium/Migration-Guide":{"url":"\/documentation\/readium\/migration-guide","kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","title":"Migration Guide","abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}],"type":"topic"},"https://www.w3.org/TR/epub-a11y-11":{"url":"https:\/\/www.w3.org\/TR\/epub-a11y-11","title":"EPUB Accessibility","titleInlineContent":[{"type":"text","text":"EPUB Accessibility"}],"type":"link","identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11"},"doc://Readium/documentation/Readium/Getting-Started":{"url":"\/documentation\/readium\/getting-started","identifier":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started","abstract":[{"type":"text","text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics."}],"kind":"article","title":"Getting started","type":"topic","role":"article"},"doc://Readium/documentation/Readium/NavigatorOverview":{"url":"\/documentation\/readium\/navigatoroverview","role":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","title":"Navigator Overview","kind":"article","abstract":[{"type":"text","text":"Learn about the architecture, configuration, and usage of the Readium Navigator."}]},"https://www.edrlab.org/readium-lcp/":{"type":"link","title":"Readium LCP","identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","titleInlineContent":[{"type":"text","text":"Readium LCP"}],"url":"https:\/\/www.edrlab.org\/readium-lcp\/"}}}