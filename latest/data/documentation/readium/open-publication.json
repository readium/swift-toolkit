{"metadata":{"title":"Opening a publication","roleHeading":"Article","role":"article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"To open a publication with Readium, you need to instantiate a couple of components: an "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" and a "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":"."}],"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"],"generated":true,"anchor":"Guides"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"AssetRetriever","text":"`AssetRetriever`","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" grants access to the content of an asset located at a given URL, such as a publication package, manifest, or LCP license."}],"type":"paragraph"},{"level":3,"anchor":"Constructing-an-AssetRetriever","text":"Constructing an `AssetRetriever`","type":"heading"},{"inlineContent":[{"text":"You can create an instance of ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" with:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"An ","type":"text"},{"code":"HTTPClient","type":"codeVoice"},{"text":" to enable the toolkit to perform HTTP requests and support the ","type":"text"},{"code":"http","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"https","type":"codeVoice"},{"text":" URL schemes. You can use ","type":"text"},{"code":"DefaultHTTPClient","type":"codeVoice"},{"text":" which provides callbacks for handling authentication when needed.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["let assetRetriever = AssetRetriever(httpClient: DefaultHTTPClient())"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Retrieving-an-Asset","text":"Retrieving an `Asset`","type":"heading"},{"inlineContent":[{"text":"With your fresh instance of ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":", you can open an ","type":"text"},{"code":"Asset","type":"codeVoice"},{"text":" from any ","type":"text"},{"code":"AbsoluteURL","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ From a local file.","let url = FileURL(string: \"file:\/\/\/path\/to\/book.epub\")","\/\/ or from an HTTP URL.","let url = HTTPURL(string: \"https:\/\/domain\/book.epub\")","","switch await assetRetriever.retrieve(url: url) {","    case .success(let asset):","        ...","    case .failure(let error):","        \/\/ Failed to retrieve the asset.","}"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!IMPORTANT]"},{"type":"text","text":" "},{"type":"text","text":"Assets created with an HTTP URL are not downloaded; they will be streamed. If that is not your intention, you need to download the file first, for example using "},{"code":"HTTPClient.download()","type":"codeVoice"},{"type":"text","text":"."}]}],"name":"Note","style":"note","type":"aside"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" will sniff the media type of the asset, which you can store in your bookshelf database to speed up the process next time you retrieve the "},{"type":"codeVoice","code":"Asset"},{"type":"text","text":". This will improve performance, especially with HTTP URL schemes."}],"type":"paragraph"},{"code":["let mediaType = asset.format.mediaType","","\/\/ Speed up the retrieval with a known media type.","let result = await assetRetriever.retrieve(url: url, mediaType: mediaType)"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"PublicationOpener","text":"`PublicationOpener`","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":" builds a "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" object from an "},{"type":"codeVoice","code":"Asset"},{"type":"text","text":" using:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"PublicationParser"},{"text":" to parse the asset structure and publication metadata.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"code":"DefaultPublicationParser","type":"codeVoice"},{"text":" handles all the formats supported by Readium out of the box.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional list of ","type":"text"},{"type":"codeVoice","code":"ContentProtection"},{"text":" to decrypt DRM-protected publications.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you support Readium LCP, you can get one from the "},{"type":"codeVoice","code":"LCPService"},{"type":"text","text":"."}]}]}]}]}],"type":"unorderedList"},{"code":["let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever,","        pdfFactory: DefaultPDFDocumentFactory()","    ),","    contentProtections: [","        lcpService.contentProtection(with: LCPDialogAuthentication())","    ]",")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Opening-a-Publication","text":"Opening a `Publication`","type":"heading"},{"inlineContent":[{"type":"text","text":"Now that you have a "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":" ready, you can use it to create a "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" from an "},{"type":"codeVoice","code":"Asset"},{"type":"text","text":" that was previously obtained using the "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"code":"allowUserInteraction","type":"codeVoice"},{"type":"text","text":" parameter is useful when supporting Readium LCP. When enabled and using a "},{"code":"LCPDialogAuthentication","type":"codeVoice"},{"type":"text","text":", the toolkit will prompt the user if the passphrase is missing."}],"type":"paragraph"},{"code":["let result = await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: sender",")"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Supporting-additional-formats-or-URL-schemes","text":"Supporting additional formats or URL schemes","type":"heading"},{"inlineContent":[{"code":"DefaultPublicationParser","type":"codeVoice"},{"type":"text","text":" accepts additional parsers. You also have the option to use your own parser list by using "},{"code":"CompositePublicationParser","type":"codeVoice"},{"type":"text","text":" or create your own "},{"code":"PublicationParser","type":"codeVoice"},{"type":"text","text":" for a fully customized parsing resolution strategy."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"AssetRetriever"},{"text":" offers an additional constructor that provides greater extensibility options, using:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ResourceFactory"},{"type":"text","text":" which handles the URL schemes through which you can access content."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"ArchiveOpener"},{"type":"text","text":" which determines the types of archives (ZIP, RAR, etc.) that can be opened by the "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FormatSniffer"},{"text":" which identifies the file formats that ","type":"text"},{"type":"codeVoice","code":"AssetRetriever"},{"text":" can recognize.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"You can use either the default implementations or implement your own for each of these components using the composite pattern. The toolkit’s "},{"type":"codeVoice","code":"CompositeResourceFactory"},{"type":"text","text":", "},{"type":"codeVoice","code":"CompositeArchiveOpener"},{"type":"text","text":", and "},{"type":"codeVoice","code":"CompositeFormatSniffer"},{"type":"text","text":" provide a simple resolution strategy."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","interfaceLanguage":"swift"},"references":{"doc://Readium/documentation/Readium/Migration-Guide":{"url":"\/documentation\/readium\/migration-guide","kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","title":"Migration Guide","abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}],"type":"topic"},"doc://Readium/documentation/Readium/NavigatorOverview":{"url":"\/documentation\/readium\/navigatoroverview","role":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","title":"Navigator Overview","kind":"article","abstract":[{"type":"text","text":"Learn about the architecture, configuration, and usage of the Readium Navigator."}]},"doc://Readium/docume