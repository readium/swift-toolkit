:"text","text":". This will improve performance, especially with HTTP URL schemes."}]},{"syntax":"swift","type":"codeListing","code":["let mediaType = asset.format.mediaType","","\/\/ Speed up the retrieval with a known media type.","let result = await assetRetriever.retrieve(url: url, mediaType: mediaType)"]},{"type":"heading","level":2,"text":"`PublicationOpener`","anchor":"PublicationOpener"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"PublicationOpener"},{"text":" builds a ","type":"text"},{"type":"codeVoice","code":"Publication"},{"text":" object from an ","type":"text"},{"type":"codeVoice","code":"Asset"},{"text":" using:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"A ","type":"text"},{"code":"PublicationParser","type":"codeVoice"},{"text":" to parse the asset structure and publication metadata.","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"DefaultPublicationParser"},{"type":"text","text":" handles all the formats supported by Readium out of the box."}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An optional list of ","type":"text"},{"type":"codeVoice","code":"ContentProtection"},{"text":" to decrypt DRM-protected publications.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"If you support Readium LCP, you can get one from the ","type":"text"},{"code":"LCPService","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}]},{"syntax":"swift","type":"codeListing","code":["let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever,","        pdfFactory: DefaultPDFDocumentFactory()","    ),","    contentProtections: [","        lcpService.contentProtection(with: LCPDialogAuthentication())","    ]",")"]},{"type":"heading","level":3,"text":"Opening a `Publication`","anchor":"Opening-a-Publication"},{"type":"paragraph","inlineContent":[{"text":"Now that you have a ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":" ready, you can use it to create a ","type":"text"},{"code":"Publication","type":"codeVoice"},{"text":" from an ","type":"text"},{"code":"Asset","type":"codeVoice"},{"text":" that was previously obtained using the ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"allowUserInteraction","type":"codeVoice"},{"text":" parameter is useful when supporting Readium LCP. When enabled and using a ","type":"text"},{"code":"LCPDialogAuthentication","type":"codeVoice"},{"text":", the toolkit will prompt the user if the passphrase is missing.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let result = await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: sender",")"]},{"type":"heading","level":2,"text":"Supporting additional formats or URL schemes","anchor":"Supporting-additional-formats-or-URL-schemes"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DefaultPublicationParser"},{"type":"text","text":" accepts additional parsers. You also have the option to use your own parser list by using "},{"type":"codeVoice","code":"CompositePublicationParser"},{"type":"text","text":" or create your own "},{"type":"codeVoice","code":"PublicationParser"},{"type":"text","text":" for a fully customized parsing resolution strategy."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" offers an additional constructor that provides greater extensibility options, using:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"