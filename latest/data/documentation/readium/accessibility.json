{"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"],"generated":true,"title":"Guides","anchor":"Guides"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"syntax":"swift","code":["let accessibility = publication.metadata.accessibility ?? Accessibility()","","if accessibility.accessModesSufficient.contains([.textual]) {","    \/\/ This publication can be read aloud with a text-to-speech engine.","}","","if accessibility.features.contains(.displayTransformability) {","    \/\/ The text and layout of this publication can be customized.","}"],"type":"codeListing"},{"level":2,"anchor":"Displaying-accessibility-metadata","type":"heading","text":"Displaying accessibility metadata"},{"inlineContent":[{"text":"While the ","type":"text"},{"isActive":true,"identifier":"https:\/\/readium.org\/webpub-manifest\/contexts\/default\/#accessibility-metadata","type":"reference"},{"text":" provide valuable information, they may be too complex and detailed to present to the user as it is. To simplify the presentation of this metadata to users, the Readium toolkit implements the ","type":"text"},{"isActive":true,"identifier":"https:\/\/w3c.github.io\/publ-a11y\/a11y-meta-display-guide\/2.0\/guidelines\/","type":"reference"},{"text":" specification, developed by the W3C.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"How-is-the-display-guide-structured","type":"heading","text":"How is the display guide structured?"},{"inlineContent":[{"type":"text","text":"The guide contains a list of fields that can be displayed as sections in your user interface. Each field has a list of related statements. For example, the "},{"code":"WaysOfReading","type":"codeVoice"},{"type":"text","text":" field provides information about whether the user can customize the text and layout ("},{"code":"visualAdjustments","type":"codeVoice"},{"type":"text","text":") or if it is readable with text-to-speech or dynamic braille ("},{"code":"nonvisualReading","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"syntax":"swift","code":["let guide = AccessibilityMetadataDisplayGuide(publication: publication)","","switch guide.waysOfReading.visualAdjustments {","case .modifiable:","    \/\/ The text and layout of the publication can be customized.","case .unmodifiable:","    \/\/ The text and layout cannot be modified.","case .unknown:","    \/\/ No metadata provided","}"],"type":"codeListing"},{"level":3,"anchor":"Localized-accessibility-statements","type":"heading","text":"Localized accessibility statements"},{"inlineContent":[{"type":"text","text":"While you are free to manually inspect the accessibility fields, the toolkit offers an API to automatically convert them into a list of localized statements (or claims) for direct display to the user."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Each statement has a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"descriptive"}]},{"type":"text","text":" variant. The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"descriptive"}]},{"type":"text","text":" string is longer and provides more details about the claim."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Compact"}],"type":"strong"},{"text":": Prerecorded audio clips","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Descriptive"}]},{"type":"text","text":": Prerecorded audio clips are embedded in the content"}]}]}],"type":"unorderedList"},{"syntax":"swift","code":["for statement in guide.waysOfReading.statements {","    print(statement.localizedString(descriptive: false))","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If translations are missing in your language, "},{"inlineContent":[{"type":"text","text":"you are encouraged to submit a contribution "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/w3c\/publ-a11y-display-guide-localizations"}],"type":"strong"},{"type":"text","text":". Alternatively, you can override or translate the strings from "},{"type":"codeVoice","code":"W3CAccessibilityMetadataDisplayGuide.strings"},{"type":"text","text":" in the host application."}],"type":"paragraph"},{"level":3,"anchor":"Displaying-all-the-recommended-fields","type":"heading","text":"Displaying all the recommended fields"},{"inlineContent":[{"type":"text","text":"If you wish to display all the accessibility fields as recommended in the official specification, you can iterate over all the fields and their statements in the guide."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"shouldDisplay","type":"codeVoice"},{"text":" property indicates whether the field does not have any meaningful statement. In which case, you may skip it in your user interface.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["for field in guide.fields {","    guard field.shouldDisplay else {","        continue","    }","","    print(\"Section: \\(field.localizedTitle)\")","","    for statement in field.statements {","        print(statement.localizedString(descriptive: false))","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Sample-implementation-in-SwiftUI","type":"heading","text":"Sample implementation in SwiftUI"},{"syntax":"swift","code":["struct AccessibilityMetadataView: View {","","    var guide: AccessibilityMetadataDisplayGuide","","    \/\/\/ Indicates whether accessibility claims are displayed in their full","    \/\/\/ descriptive statements.","    @State private var showDescriptive: Bool = false","","    var body: some View {","        List {","            Text(\"Accessibility Claims\")","                .font(.title)","","            Toggle(\"Show descriptive statements\", isOn: $showDescriptive)","","            ForEach(guide.fields, id: \\.id) { field in","                if field.shouldDisplay {","                    Section(field.localizedTitle) {","                        ForEach(field.statements) { statement in","                            Text(AttributedString(statement.localizedString(descriptive: showDescriptive)))","                        }","                    }","                }","            }","        }","    }","}"],"type":"codeListing"}]}],"metadata":{"role":"article","roleHeading":"Article","title":"Accessibility"},"sections":[],"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"abstract":[{"type":"text","text":"Some publications declare their accessibility features and limitations as metadata which broadly mirror the "},{"identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","type":"reference","isActive":true},{"type":"text","text":" specification."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Accessibility","interfaceLanguage":"swift"},"references":{"https://www.edrlab.org/readium-lcp/":{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","titleInlineContent":[{"type":"text","text":"Readium LCP"}],"type":"link","title":"Readium LCP","url":"https:\/\/www.edrlab.org\/readium-lcp\/"},"doc://Readium/documentation/Readium/Migration-Guide":{"url":"\/documentation\/readium\/migration-guide","kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","title":"Migration Guide","abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}],"type":"topic"},"doc://Readium/documentation/Readium/TTS":{"abstract":[],"type":"topic","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","url":"\/documentation\/readium\/tts","title":"Text-to-speech","kind":"article"},"doc://Readium/documentation/Readium/Content":{"type":"topic","abstract":[],"kind":"article","role":"article","url":"\/documentation\/readium\/content","title":"Extracting the content of a publication","identifier":"doc:\/\/Readium\/documentation\/Readium\/Content"},"doc://Readium/documentation/Readium/NavigatorOverview":{"url":"\/documentation\/readium\/navigatoroverview","role":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","title":"Navigator Overview","kind":"article","abstract":[{"type":"text","text":"Learn about the architecture, configuration, and usage of the Readium Navigator."}]},"doc://Readium/documentation/Readium/Getting-Started":{"url":"\/documentation\/readium\/getting-started","identifier":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started","abstract":[{"type":"text","text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics."}],"kind":"article","title":"Getting started","type":"topic","role":"article"},"doc://Readium/documentation/Readium/Open-Publication":{"abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"type":"codeVoice","code":"AssetRetriever"},{"text":" and a ","type":"text"},{"type":"codeVoice","code":"PublicationOpener"},{"text":".","type":"text"}],"kind":"article","type":"topic","title":"Opening a publication","identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","url":"\/documentation\/readium\/open-publication","role":"article"},"https://github.com/w3c/publ-a11y-display-guide-localizations":{"identifier":"https:\/\/github.com\/w3c\/publ-a11y-display-guide-localizations","titleInlineContent":[{"type":"text","text":"to the official W3C repository"}],"type":"link","title":"to the official W3C repository","url":"https:\/\/github.com\/w3c\/publ-a11y-display-guide-localizations"},"doc://Readium/documentation/Readium":{"abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"role":"collection","title":"Readium","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium","url":"\/documentation\/readium","kind":"article"},"doc://Readium/documentation/Readium/Readium-LCP":{"url":"\/documentation\/readium\/readium-lcp","title":"Supporting Readium LCP","abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","type":"reference","isActive":true},{"text":" DRM.","type":"text"}],"kind":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","type":"topic","role":"article"},"https://w3c.github.io/publ-a11y/a11y-meta-display-guide/2.0/guidelines/":{"identifier":"https:\/\/w3c.github.io\/publ-a11y\/a11y-meta-display-guide\/2.0\/guidelines\/","titleInlineContent":[{"type":"text","text":"Accessibility Metadata Display Guide"}],"type":"link","title":"Accessibility Metadata Display Guide","url":"https:\/\/w3c.github.io\/publ-a11y\/a11y-meta-display-guide\/2.0\/guidelines\/"},"https://readium.org/webpub-manifest/contexts/default/#accessibility-metadata":{"identifier":"https:\/\/readium.org\/webpub-manifest\/contexts\/default\/#accessibility-metadata","titleInlineContent":[{"type":"text","text":"RWPM Accessibility models"}],"type":