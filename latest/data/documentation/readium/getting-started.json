[{"text":"OPDS catalog feeds","type":"text"}],"url":"https:\/\/opds.io"},"doc://Readium/documentation/Readium/Open-Publication":{"abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" and a ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","kind":"article","title":"Opening a publication","role":"article","url":"\/documentation\/readium\/open-publication"},"doc://Readium/documentation/Readium/Migration-Guide":{"abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}],"url":"\/documentation\/readium\/migration-guide","role":"article","kind":"article","title":"Migration Guide","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","type":"topic"}}}