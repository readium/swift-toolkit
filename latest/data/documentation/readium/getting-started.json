{"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"title":"Getting started","role":"article","roleHeading":"Article"},"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"],"generated":true,"anchor":"Guides"}],"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!NOTE]"},{"type":"text","text":" "},{"type":"text","text":"Readium offers only low-level tools. You are responsible for creating a user interface for reading and managing books, as well as a data layer to store the user’s publications. The Test App is an example of such integration."}]}]},{"text":"Design principles","anchor":"Design-principles","type":"heading","level":2},{"inlineContent":[{"text":"The toolkit has been designed following these core tenets:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modular"}]},{"type":"text","text":": It is divided into separate modules that can be used independently."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Extensible","type":"text"}]},{"type":"text","text":": Integrators should be able to support a custom DRM, publication format or inject their own stylesheets without modifying the toolkit itself."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Opiniated","type":"text"}],"type":"strong"},{"text":": We adhere to open standards but sometimes interpret them for practicality.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Packages","anchor":"Packages","type":"heading","level":2},{"text":"Main packages","anchor":"Main-packages","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ReadiumShared"},{"text":" contains shared ","type":"text"},{"type":"codeVoice","code":"Publication"},{"text":" models and utilities.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"ReadiumStreamer"},{"text":" parses publication files (e.g. an EPUB) into a ","type":"text"},{"type":"codeVoice","code":"Publication"},{"text":" object.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"Navigator\/Navigator.md","type":"reference","isActive":true},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"text":"Specialized packages","anchor":"Specialized-packages","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"ReadiumOPDS","type":"codeVoice"},{"text":" parses ","type":"text"},{"identifier":"https:\/\/opds.io","isActive":true,"type":"reference"},{"text":" (both OPDS 1 and 2).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"Readium%20LCP.md","type":"reference","isActive":true},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"text":"Adapters to third-party dependencies","anchor":"Adapters-to-third-party-dependencies","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ReadiumAdapterGCDWebServer"},{"type":"text","text":" provides an HTTP server built with "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/swisspol\/GCDWebServer"},{"type":"text","text":", used by the PDF navigator."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Overview of the shared models (`ReadiumShared`)","anchor":"Overview-of-the-shared-models-ReadiumShared","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Readium toolkit provides models used as exchange types between packages."}]},{"text":"Publication models","anchor":"Publication-models","type":"heading","level":3},{"text":"Publication","anchor":"Publication","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"code":"Publication","type":"codeVoice"},{"text":" and its sub-components represent a single publication – ebook, audiobook or comic. It is loosely based on the ","type":"text"},{"identifier":"https:\/\/readium.org\/webpub-manifest\/","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"Publication","type":"codeVoice"},{"text":" instance:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"holds the metadata of a publication, such as its author or table of contents,","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"allows to read the contents of a publication, e.g. XHTML or audio resources,","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"provides additional services, for example content extraction or text search.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Link","anchor":"Link","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"https:\/\/readium.org\/webpub-manifest\/#24-the-link-object","isActive":true},{"type":"text","text":" holds a pointer (URL) to a resource or service along with additional metadata, such as its media type or title."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"Publication","type":"codeVoice"},{"type":"text","text":" contains several "},{"code":"Link","type":"codeVoice"},{"type":"text","text":" collections, for example:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"readingOrder","type":"codeVoice"},{"text":" lists the publication resources arranged in the order they should be read.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"resources"},{"type":"text","text":" contains secondary resources necessary for rendering the "},{"type":"codeVoice","code":"readingOrder"},{"type":"text","text":", such as an image or a font file."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"tableOfContents"},{"type":"text","text":" represents the table of contents as a tree of "},{"type":"codeVoice","code":"Link"},{"type":"text","text":" objects."}]}]},{"content":[{"inlineContent":[{"code":"links","type":"codeVoice"},{"text":" exposes additional resources, such as a canonical link to the manifest or a search web service.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Locator","level":4,"text":"Locator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"https:\/\/readium.org\/architecture\/models\/locators\/","type":"reference","isActive":true},{"type":"text","text":" represents a precise location in a publication resource in a format that can be stored and shared across reading systems. It is more accurate than a "},{"type":"codeVoice","code":"Link"},{"type":"text","text":" and contains additional information about the location, e.g. progression percentage, position or textual context."}]},{"type":"paragraph","inlineContent":[{"code":"Locator","type":"codeVoice"},{"type":"text","text":" objects are used for various features, including:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"reporting the current progression in the publication"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"saving bookmarks, highlights and annotations"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"navigating search results"}]}]}]},{"type":"heading","anchor":"Data-models","level":3,"text":"Data models"},{"type":"heading","anchor":"Asset","level":4,"text":"Asset"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"code":"Asset","type":"codeVoice"},{"text":" represents a single file or package and provides access to its content. There are two types of ","type":"text"},{"code":"Asset","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ContainerAsset"},{"type":"text","text":" for packages which contains several resources, such as a ZIP archive."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ResourceAsset"},{"type":"text","text":" for accessing a single resource, such as a JSON or PDF file."}]}]}]},{"type":"paragraph","inlineContent":[{"code":"Asset","type":"codeVoice"},{"text":" instances are obtained through an ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can use the ","type":"text"},{"type":"codeVoice","code":"asset.format"},{"text":" to identify the media type and capabilities of the asset.","type":"text"}]},{"type":"codeListing","code":["if asset.format.conformsTo(.lcp) {","    \/\/ The asset is protected with LCP.","}","if asset.format.conformsTo(.epub) {","    \/\/ The asset represents an EPUB publication.","}"],"syntax":"swift"},{"type":"heading","anchor":"Resource","level":4,"text":"Resource"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"Resource"},{"type":"text","text":" provides read access to a single resource, such as a file or an entry in an archive."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Resource"},{"text":" instances are usually created by a ","type":"text"},{"type":"codeVoice","code":"ResourceFactory"},{"text":". The toolkit ships with various implementations supporting different data access protocols such as local files or HTTP.","type":"text"}]},{"type":"heading","anchor":"Container","level":4,"text":"Container"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"Container","type":"codeVoice"},{"type":"text","text":" provides read access to a collection of resources. "},{"code":"Container","type":"codeVoice"},{"type":"text","text":" instances representing an archive are usually created by an "},{"code":"ArchiveOpener","type":"codeVoice"},{"type":"text","text":". The toolkit ships with a "},{"code":"ZIPArchiveOpener","type":"codeVoice"},{"type":"text","text":" supporting both local and remote (HTTP) ZIP files."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Publication"},{"type":"text","text":" objects internally use a "},{"type":"codeVoice","code":"Container"},{"type":"text","text":" to expose its content."}]},{"type":"heading","anchor":"Opening-a-publication-ReadiumStreamer","level":2,"text":"Opening a publication (`ReadiumStreamer`)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To retrieve a "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" object from a publication file like an EPUB or audiobook, you can use an "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" and "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":"."}]},{"type":"codeListing","code":["\/\/ Instantiate the required components.","let httpClient = DefaultHTTPClient()","let assetRetriever = AssetRetriever(","    httpClient: httpClient",")","let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever,","        pdfFactory: DefaultPDFDocumentFactory()","    )",")","","let url: URL = URL(...)","","\/\/ Retrieve an `Asset` to access the file content.","switch await assetRetriever.retrieve(url: url.anyURL.absoluteURL!) {","case .success(let asset):","    \/\/ Open a `Publication` from the `Asset`.","    switch await publicationOpener.open(asset: asset, allowUserInteraction: true, sender: view) {","    case .success(let publication):","        print(\"Opened \\(publication.metadata.title)\")","","    case .failure(let error):","        \/\/ Failed to access or parse the publication","    }","","case .failure(let error):","    \/\/ Failed to retrieve the asset","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"allowUserInteraction"},{"type":"text","text":" parameter is useful when supporting a DRM like Readium LCP. It indicates if the toolkit can prompt the user for credentials when the publication is protected."}]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"Open%20Publication.md","isActive":true},{"type":"text","text":"."}]},{"type":"heading","anchor":"Accessing-the-metadata-of-a-publication","level":2,"text":"Accessing the metadata of a publication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After opening a publication, you may want to read its metadata to insert a new entity into your bookshelf database, for instance. The "},{"code":"publication.metadata","type":"codeVoice"},{"type":"text","text":" object contains everything you need, including "},{"code":"title","type":"codeVoice"},{"type":"text","text":", "},{"code":"authors","type":"codeVoice"},{"type":"text","text":" and the "},{"code":"published","type":"codeVoice"},{"type":"text","text":" date."}]},{"type":"paragraph","inlineContent":[{"text":"You can retrieve the publication cover using ","type":"text"},{"type":"codeVoice","code":"await publication.cover()"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Rendering-the-publication-on-the-screen-ReadiumNavigator","level":2,"text":"Rendering the publication on the screen (`ReadiumNavigator`)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a Readium navigator to present the publication to the user. The "},{"type":"codeVoice","code":"Navigator"},{"type":"text","text":" renders resources on the screen and offers APIs and user interactions for navigating the contents."}]},{"type":"paragraph","inlineContent":[{"text":"Please refer to the ","type":"text"},{"overridingTitle":"Navigator guide","identifier":"Navigator\/Navigator.md","overridingTitleInlineContent":[{"text":"Navigator guide","type":"text"}],"isActive":true,"type":"reference"},{"text":" for more information.","type":"text"}]}]}],"abstract":[{"type":"text","text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics."}],"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"references":{"https://readium.org/webpub-manifest/#24-the-link-object":{"url":"https:\/\/readium.org\/webpub-manifest\/#24-the-link-object","type":"link","identifier":"https:\/\/readium.org\/webpub-manifest\/#24-the-link-object","title":"Link object","titleInlineContent":[{"code":"Link","type":"codeVoice"},{"text":" object","type":"text"}]},"https://www.edrlab.org/readium-lcp/":{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","title":"Readium LCP","type":"link","titleInlineContent":[{"text":"Readium LCP","type":"text"}],"url":"https:\/\/www.edrlab.org\/readium-lcp\/"},"https://readium.org/webpub-manifest/":{"url":"https:\/\/readium.org\/webpub-manifest\/","type":"link","identifier":"https:\/\/readium.org\/webpub-manifest\/","title":"Readium Web Publication Manifest","titleInlineContent":[{"text":"Readium Web Publication Manifest","type":"text"}]},"doc://Readium/documentation/Readium/TTS":{"title":"Text-to-speech","identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","kind":"article","abstract":[],"type":"topic","role":"article","url":"\/documentation\/readium\/tts"},"Readium%20LCP.md":{"identifier":"Readium%20LCP.md","title":"ReadiumLCP downloads and decrypts LCP-protected publications","type":"link","titleInlineContent":[{"code":"ReadiumLCP","type":"codeVoice"},{"text":" downloads and decrypts LCP-protected publications","type":"text"}],"url":"Readium%20LCP.md"},"https://www.w3.org/TR/epub-a11y-11":{"url":"https:\/\/www.w3.org\/TR\/epub-a11y-11","type":"link","identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","title":"EPUB Accessibility","titleInlineContent":[{"text":"EPUB Accessibility","type":"text"}]},"doc://Readium/documentation/Readium/Content":{"abstract":[],"url":"\/documentation\/readium\/content","role":"article","kind":"article","title":"Extracting the content of a publication","identifier":"doc:\/\/Readium\/documentation\/Readium\/Content","type":"topic"},"Open%20Publication.md":{"identifier":"Open%20Publication.md","title":"See the dedicated user guide for more information","type":"link","titleInlineContent":[{"text":"See the dedicated user guide for more information","type":"text"}],"url":"Open%20Publication.md"},"doc://Readium/documentation/Readium/Readium-LCP":{"role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","url":"\/documentation\/readium\/readium-lcp","type":"topic","title":"Supporting Readium LCP","kind":"article","abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.edrlab.org\/readium-lcp\/"},{"text":" DRM.","type":"text"}]},"doc://Readium/documentation/Readium/Accessibility":{"title":"Accessibility","kind":"article","abstract":[{"type":"text","text":"Some publications declare their accessibility features and limitations as metadata which broadly mirror the "},{"ide