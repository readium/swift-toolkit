{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!IMPORTANT]"},{"type":"text","text":" "},{"type":"text","text":"Navigators do not have user interfaces besides the view that displays the publication. Applications are responsible for providing a user interface with bookmark buttons, a progress bar, etc."}]}]},{"type":"heading","level":2,"text":"Default implementations","anchor":"Default-implementations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Readium toolkit comes with several "},{"type":"codeVoice","code":"Navigator"},{"type":"text","text":" implementations for different publication profiles. Some are "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"s, designed to be added to your view hierarchy, while others are chromeless and can be used in the background."}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Navigator","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Profile","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Formats","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"EPUBNavigatorViewController","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"epub"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"EPUB ("},{"type":"codeVoice","code":".epub"},{"type":"text","text":"), Readium Web Publication ("},{"type":"codeVoice","code":".webpub"},{"type":"text","text":")"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"PDFNavigatorViewController"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"pdf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"PDF (","type":"text"},{"type":"codeVoice","code":".pdf"},{"text":"), LCP-protected PDF (","type":"text"},{"type":"codeVoice","code":".lcpdf"},{"text":")","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CBZNavigatorViewController"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"divina"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Zipped Comic Book (","type":"text"},{"code":"cbz","type":"codeVoice"},{"text":"), Readium Divina (","type":"text"},{"code":".divina","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"AudioNavigator","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"audiobook","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Zipped Audio Book (","type":"text"},{"type":"codeVoice","code":".zab"},{"text":"), Readium Audiobook (","type":"text"},{"type":"codeVoice","code":".audiobook"},{"text":", ","type":"text"},{"type":"codeVoice","code":".lcpa"},{"text":")","type":"text"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"text":"To find out which Navigator is compatible with a publication, refer to its ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/readium.org\/webpub-manifest\/profiles\/"},{"text":". Use ","type":"text"},{"type":"codeVoice","code":"publication.conforms(to:)"},{"text":" to identify the publication’s profile.","type":"text"}]},{"type":"codeListing","code":["if publication.conforms(to: .epub) {","    let navigator = try EPUBNavigatorViewController(","        publication: publication,","        initialLocation: lastReadLocation","    )","","    hostViewController.present(navigator, animated: true)","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Navigator APIs","anchor":"Navigator-APIs"},{"type":"paragraph","inlineContent":[{"text":"Navigators implement a set of shared interfaces to help reuse the reading logic across publication profiles. For example, instead of using specific implementations like ","type":"text"},{"code":"EPUBNavigatorViewController","type":"codeVoice"},{"text":", use the ","type":"text"},{"code":"Navigator","type":"codeVoice"},{"text":" interface to create a location history manager compatible with all Navigator types.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can create custom Navigators and easily integrate them into your app with minimal modifications by implementing these interfaces.","type":"text"}]},{"type":"heading","level":3,"text":"`Navigator` interface","anchor":"Navigator-interface"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All Navigators implement the "},{"code":"Navigator","type":"codeVoice"},{"type":"text","text":" interface, which provides the foundation for navigating resources in a "},{"code":"Publication","type":"codeVoice"},{"type":"text","text":". You can use it to move through the publication’s content or to find the current position."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this interface does not specify how the content is presented to the user."}]},{"type":"heading","level":3,"text":"`VisualNavigator` interface","anchor":"VisualNavigator-interface"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigators rendering the content visually on the screen implement the "},{"type":"codeVoice","code":"VisualNavigator"},{"type":"text","text":" interface. This interface offers details about the presentation style (e.g., scrolled, right-to-left, etc.) and allows monitoring input events like taps or keyboard strokes."}]},{"type":"heading","level":3,"text":"`SelectableNavigator` interface","anchor":"SelectableNavigator-interface"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigators enabling users to select parts of the content implement "},{"type":"codeVoice","code":"SelectableNavigator"},{"type":"text","text":". You can use it to extract the "},{"type":"codeVoice","code":"Locator"},{"type":"text","text":" and content of the selected portion."}]},{"type":"heading","level":3,"text":"`DecorableNavigator` interface","anchor":"DecorableNavigator-interface"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Decorable Navigator is able to render decorations over a publication, such as highlights or margin icons."}]},{"type":"paragraph","inlineContent":[{"text":"To implement user highlights in your app, see the ","type":"text"},{"identifier":"Highlights.md","type":"reference","isActive":true},{"text":". For a deeper look at the API or to build a custom decoration style, see the ","type":"text"},{"identifier":"Decorations.md","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Instantiating a Navigator","anchor":"Instantiating-a-Navigator"},{"type":"heading","level":3,"text":"Visual Navigators","anchor":"Visual-Navigators"},{"type":"paragraph","inlineContent":[{"text":"The Visual Navigators are implemented as ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" and must be added to your iOS view hierarchy to render the publication contents.","type":"text"}]},{"type":"codeListing","code":["let navigator = try EPUBNavigatorViewController(","    publication: publication,","    initialLocation: lastReadLocation",")","","hostViewController.present(navigator, animated: true)"],"syntax":"swift"},{"type":"heading","level":3,"text":"Audio Navigator","anchor":"Audio-Navigator"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"AudioNavigator","type":"codeVoice"},{"text":" is chromeless and does not provide any user interface, allowing you to create your own custom UI.","type":"text"}]},{"type":"codeListing","code":["let navigator = AudioNavigator(","    publication: publication,","    initialLocation: lastReadLocation",")","","navigator.play()"],"syntax":"swift"},{"type":"heading","level":2,"text":"Navigating the contents of the publication","anchor":"Navigating-the-contents-of-the-publication"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"Navigator"},{"text":" interface offers various ","type":"text"},{"type":"codeVoice","code":"go"},{"text":" APIs for navigating the publication. For instance:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"to the previous or next pages: "},{"type":"codeVoice","code":"navigator.goForward()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"navigator.goBackward()"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"to a link from the "},{"type":"codeVoice","code":"publication.tableOfContents"},{"type":"text","text":" or "},{"type":"codeVoice","code":"publication.readingOrder"},{"type":"text","text":": "},{"type":"codeVoice","code":"navigator.go(to: link)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"to a locator from a search result: ","type":"text"},{"code":"navigator.go(to: locator)","type":"codeVoice"}]}]}]},{"type":"heading","level":2,"text":"Reading progression","anchor":"Reading-progression"},{"type":"heading","level":3,"text":"Saving and restoring the last read location","anchor":"Saving-and-restoring-the-last-read-location"},{"type":"paragraph","inlineContent":[{"text":"Navigators don’t store any data permanently. Therefore, it is your responsibility to save the last read location in your database and restore it when creating a new Navigator.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can observe the current position in the publication by implementing a "},{"code":"NavigatorDelegate","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","code":["navigator.delegate = MyNavigatorDelegate()","","@MainActor class MyNavigatorDelegate: NavigatorDelegate {","","    func navigator(_ navigator: Navigator, locationDidChange locator: Locator) {","        if let position = locator.locations.position {","            print(\"At position \\(position)\")","        }","        if let progression = locator.locations.progression {","            print(\"Progression in the current resource: \\(progression.formatted(.percent))\")","        }","        if let totalProgression = locator.locations.totalProgression {","            print(\"Total progression in the publication: \\(totalProgression.formatted(.percent))\")","        }","","        \/\/ Save the position in your bookshelf database","        database.saveLastReadLocation(locator.jsonString)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"Locator","type":"codeVoice"},{"text":" object may be serialized to JSON in your database, and deserialized to set the initial location when creating the navigator.","type":"text"}]},{"type":"codeListing","code":["let lastReadLocation = try? Locator(jsonString: database.lastReadLocation())","","let navigator = try EPUBNavigatorViewController(","    publication: publication,","    initialLocation: lastReadLocation",")"],"syntax":"swift"},{"type":"heading","level":3,"text":"Bookmarking the current location","anchor":"Bookmarking-the-current-location"},{"type":"paragraph","inlineContent":[{"text":"Use a Navigator’s ","type":"text"},{"code":"currentLocation","type":"codeVoice"},{"text":" property to persists the current position, for instance as a bookmark.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"After the user selects a bookmark from your user interface, navigate to it using ","type":"text"},{"code":"navigator.go(bookmark.locator)","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Displaying a progression slider","anchor":"Displaying-a-progression-slider"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To display a percentage-based progression slider, use the "},{"type":"codeVoice","code":"locations.totalProgression"},{"type":"text","text":" property of the "},{"type":"codeVoice","code":"currentLocation"},{"type":"text","text":". This property holds the total progression across an entire publication."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given a progression from 0 to 1, you can obtain a "},{"type":"codeVoice","code":"Locator"},{"type":"text","text":" object from the "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":". This can be used to navigate to a specific percentage within the publication."}]},{"type":"codeListing","code":["if let locator = await publication.locate(progression: 0.5) {","    await navigator.go(to: locator)","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Displaying the number of positions","anchor":"Displaying-the-number-of-positions"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"Readium does not have the concept of pages, as they are not useful when dealing with reflowable publications across different screen sizes. Instead, we use ","type":"text"},{"identifier":"https:\/\/readium.org\/architecture\/models\/locators\/positions\/","isActive":true,"type":"reference"},{"text":" which remain stable even when the user changes the font size or device.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Not all Navigators provide positions, but most ","type":"text"},{"code":"VisualNavigator","type":"codeVoice"},{"text":" implementations do. To find the total positions in the publication, use ","type":"text"},{"code":"try await publication.positions().get().count","type":"codeVoice"},{"text":". You can get the current position with ","type":"text"},{"code":"navigator.currentLocation?.locations.position","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Navigating with edge taps and keyboard arrows","anchor":"Navigating-with-edge-taps-and-keyboard-arrows"},{"type":"paragraph","inlineContent":[{"text":"Readium provides a ","type":"text"},{"type":"codeVoice","code":"DirectionalNavigationAdapter"},{"text":" helper to turn pages when the user taps the edge of the screen or presses the arrow or space keys.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Bind it to your ","type":"text"},{"code":"Navigator","type":"codeVoice"},{"text":" instance before adding your own input observers, so it takes precedence.","type":"text"}]},{"type":"codeListing","code":["DirectionalNavigationAdapter().bind(to: navigator)","","\/\/ Toggle the navigation bar when the user taps outside the edge zones.","token = navigator.addObserver(.tap { [weak self] _ in","    self?.toggleNavigationBar()","    return true","})"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"code":"DirectionalNavigationAdapter","type":"codeVoice"},{"text":" offers many customization options. Take a look at its API.","type":"text"}]},{"type":"heading","level":2,"text":"User preferences","anchor":"User-preferences"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Readium Navigators support user preferences, such as font size or background color. Take a look at "},{"identifier":"Preferences.md","type":"reference","isActive":true},{"type":"text","text":" for more information."}]}]}],"kind":"article","abstract":[{"type":"text","text":"You can use a Readium Navigator to present the publication to the user. The "},{"type":"codeVoice","code":"Navigator"},{"type":"text","text":" renders resources on the screen and offers APIs and user interactions for navigating the contents."}],"metadata":{"title":"Navigator","role":"article","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview"]]},"seeAlsoSections":[{"anchor":"Essentials","generated":true,"title":"Essentials","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Preferences","doc:\/\/Readium\/documentation\/Readium\/SwiftUI","doc:\/\/Readium\/documentation\/Readium\/Input","doc:\/\/Readium\/documentation\/Readium\/Highlights","doc:\/\/Readium\/documentation\/Readium\/Decorations","doc:\/\/Readium\/documentation\/Readium\/EPUB-Fonts"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Readium\/documentation\/Readium\/Navigator"},"references":{"Preferences.md":{"type":"link","title":"EPUB navigator preferences","identifier":"Preferences.md","url":"Preferences.md","titleInlineContent":[{"type":"text","text":"EPUB navigator preferences"}]},"https://developer.apple.com/documentation/swiftui/uiviewrepresentable":{"identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/uiviewrepresentable","url":"https:\/\/developer.apple.com\/documentation\/swiftui\/uiviewrepresentable","type":"link","title":"UIViewRepresentable","titleInlineContent":[{"type":"codeVoice","code":"UIViewRepresentable"}]},"doc://Readium/documentation/Readium/EPUB-Fonts":{"type":"topic","title":"Font families in the EPUB navigator","kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/EPUB-Fonts","abstract":[{"type":"text","text":"Readium allows users to customize the font family used to render a reflowable EPUB, by changing the "},{"type":"reference","identifier":"Preferences.md","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/readium\/epub-fonts"},"doc://Readium/documentation/Readium/Highlights":{"title":"Implementing Highlights","url":"\/documentation\/readium\/highlights","abstract":[{"text":"Highlighting lets users mark up passages in a publication for later reference - a core feature of any reading app. In Readium, highlights are built on top of the ","type":"text"},{"inlineContent":[{"type":"text","text":"Decoration API"}],"type":"strong"},{"text":". If you want to understand that API in depth or build a custom decoration style, see the ","type":"text"},{"isActive":true,"type":"reference","identifier":"Decorations.md"},{"text":".","type":"text"}],"kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Highlights","type":"topic"},"Highlights.md":{"type":"link","title":"Highlighting guide","identifier":"Highlights.md","url":"Highlights.md","titleInlineContent":[{"type":"text","text":"Highlighting guide"}]},"https://readium.org/webpub-manifest/profiles/":{"identifier":"https:\/\/readium.org\/webpub-manifest\/profiles\/","url":"https:\/\/readium.org\/webpub-manifest\/profiles\/","type":"link","title":"profile","titleInlineContent":[{"type":"text","text":"profile"}]},"doc://Readium/documentation/Readium/NavigatorOverview":{"url":"\/documentation\/readium\/navigatoroverview","title":"Navigator Overview","kind":"article","type":"topic","abstract":[{"type":"text","text":"Learn about the architecture, configuration, and usage of the Readium Navigator."}],"role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview"},"doc://Readium/documentation/Readium/Input":{"title":"Observing user input","identifier":"doc:\/\/Readium\/documentation\/Readium\/Input","type":"topic","kind":"article","role":"article","url":"\/documentation\/readium\/input","abstract":[{"text":"In visual publications like EPUB or PDF, users can interact with the ","type":"text"},{"code":"VisualNavigator","type":"codeVoice"},{"text":" instance using gestures, a keyboard, a mouse, a pencil, or a trackpad. When the publication does not override user input events, you may want to intercept them to trigger actions in your user interface. For example, you can turn pages or toggle the navigation bar on taps, or open a bookmarks screen when pressing the Command-Shift-D hotkey.","type":"text"}]},"doc://Readium/documentation/Readium":{"abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"identifier":"doc:\/\/Readium\/documentation\/Readium","title":"Readium","kind":"article","role":"collection","type":"topic","url":"\/documentation\/readium"},"Decorations.md":{"type":"link","title":"Decorations guide","identifier":"Decorations.md","url":"Decorations.md","titleInlineContent":[{"type":"text","text":"Decorations guide"}]},"doc://Readium/documentation/Readium/Preferences":{"title":"Configuring the Navigator","url":"\/documentation\/readium\/preferences","abstract":[{"text":"Take a look at the ","type":"text"},{"isActive":true,"identifier":"..\/Migration%20Guide.md","type":"reference"},{"text":" if you are already using the legacy EPUB settings.","type":"text"}],"kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Preferences","type":"topic"},"doc://Readium/documentation/Readium/Decorations":{"type":"topic","title":"Decorations","identifier":"doc:\/\/Readium\/documentation\/Readium\/Decorations","url":"\/documentation\/readium\/decorations","kind":"article","abstract":[{"text":"The Decoration API lets you overlay visual elements on publication content – highlights, search result markers, TTS playback indicators, page-number labels in the margin, and more. For the common case of implementing user highlights, see the ","type":"text"},{"identifier":"Highlights.md","isActive":true,"type":"reference"},{"text":".","type":"text"}],"role":"article"},"https://readium.org/architecture/models/locators/positions/":{"identifier":"https:\/\/readium.org\/architecture\/models\/locators\/positions\/","url":"https:\/\/readium.org\/architecture\/models\/locators\/positions\/","type":"link","title":"positions","titleInlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"positions"}]}]},"doc://Readium/documentation/Readium/SwiftUI":{"url":"\/documentation\/readium\/swiftui","type":"topic","abstract":[{"text":"The Navigator is built with UIKit and provides ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" implementations. Nevertheless, you can integrate them into a SwiftUI view hierarchy using Apple’s ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/uiviewrepresentable","type":"reference","isActive":true},{"text":".","type":"text"}],"role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/SwiftUI","kind":"article","title":"Integrating the Navigator with SwiftUI"},"../Migration%20Guide.md":{"type":"link","title":"migration guide","identifier":"..\/Migration%20Guide.md","url":"..\/Migration%20Guide.md","titleInlineContent":[{"type":"text","text":"migration guide"}]}}}