{"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/JSONEquatable","doc:\/\/Readium\/s28CustomDebugStringConvertibleP","doc:\/\/Readium\/SQ"],"type":"conformsTo","kind":"relationships"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DOMRange"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In a DOM Range object, the startContainer + startOffset tuple represents the ","type":"text"},{"type":"codeVoice","code":"start"},{"text":" boundary","type":"text"},{"text":" ","type":"text"},{"text":"point. Similarly, the the endContainer + endOffset tuple represents the ","type":"text"},{"type":"codeVoice","code":"end"},{"text":" boundary point.","type":"text"},{"text":" ","type":"text"},{"text":"In both cases, the start\/endContainer property is a pointer to either a DOM text node, or a DOM","type":"text"},{"text":" ","type":"text"},{"text":"element (this typically depends on the mechanism from which the DOM Range instance originates,","type":"text"},{"text":" ","type":"text"},{"text":"for example when obtaining the currently-selected document fragment using the ","type":"text"},{"type":"codeVoice","code":"window.selection"},{"text":" ","type":"text"},{"text":"API). In the case of a DOM text node, the start\/endOffset corresponds to a position within the","type":"text"},{"text":" ","type":"text"},{"text":"character data. In the case of a DOM element node, the start\/endOffset corresponds to a position","type":"text"},{"text":" ","type":"text"},{"text":"that designates a child text node.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"code":"end","type":"codeVoice"},{"type":"text","text":" field is optional. When only the start field is specified, the domRange object"},{"type":"text","text":" "},{"type":"text","text":"represents a “collapsed” range that has identical "},{"code":"start","type":"codeVoice"},{"type":"text","text":" and "},{"code":"end","type":"codeVoice"},{"type":"text","text":" boundary points."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"https:\/\/github.com\/readium\/architecture\/blob\/master\/models\/locators\/extensions\/html.md#the-domrange-object"}]}]}],"abstract":[{"text":"This construct enables a serializable representation of a DOM Range.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/readiumshared\/domrange"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange"},"metadata":{"externalID":"s:13ReadiumShared8DOMRangeV","modules":[{"name":"ReadiumShared"}],"role":"symbol","title":"DOMRange","roleHeading":"Structure","navigatorTitle":[{"text":"DOMRange","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DOMRange"}],"symbolKind":"struct"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"title":"Structures","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange\/Point"],"generated":true,"anchor":"Structures"},{"title":"Initializers","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange\/init(json:warnings:)","doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange\/init(start:end:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange\/json"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange\/CustomDebugStringConvertible-Implementations","doc:\/\/Readium\/documentation\/ReadiumShared\/DOMRange\/Equatable