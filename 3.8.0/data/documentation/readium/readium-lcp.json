{"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility"],"generated":true}],"abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","isActive":true,"type":"reference"},{"text":" DRM.","type":"text"}],"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","interfaceLanguage":"swift"},"metadata":{"title":"Supporting Readium LCP","role":"article","roleHeading":"Article"},"kind":"article","sections":[],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!IMPORTANT]"},{"type":"text","text":" "},{"type":"text","text":"To use LCP with the Readium toolkit, you must first obtain the "},{"type":"codeVoice","code":"R2LCPClient"},{"type":"text","text":" private library by contacting "},{"type":"reference","identifier":"https:\/\/www.edrlab.org\/contact\/","isActive":true},{"type":"text","text":"."}]}],"type":"aside","style":"note","name":"Note"},{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An LCP publication is protected with a "},{"inlineContent":[{"type":"text","text":"user passphrase"}],"type":"emphasis"},{"type":"text","text":" and distributed using an LCP License Document ("},{"code":".lcpl","type":"codeVoice"},{"type":"text","text":") ."}]},{"type":"paragraph","inlineContent":[{"text":"The user flow typically goes as follows:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The user imports a ","type":"text"},{"type":"codeVoice","code":".lcpl"},{"text":" file into your application.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The application uses the Readium toolkit to download the protected publication from the ","type":"text"},{"code":".lcpl","type":"codeVoice"},{"text":" file to the user’s bookshelf. The downloaded file can be a ","type":"text"},{"code":".epub","type":"codeVoice"},{"text":", ","type":"text"},{"code":".lcpdf","type":"codeVoice"},{"text":" (PDF), or ","type":"text"},{"code":".lcpa","type":"codeVoice"},{"text":" (audiobook) package.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user opens the protected publication from the bookshelf."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the passphrase isn’t already recorded in the "},{"type":"codeVoice","code":"ReadiumLCP"},{"type":"text","text":" internal database, the user will be asked to enter it to unlock the contents."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The publication is decrypted and rendered on the screen."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Setup","anchor":"Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To support LCP in your application, you require two components:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" package from the toolkit provides APIs for downloading and decrypting protected publications. Import it as you would any other Readium package, such as ","type":"text"},{"code":"R2Navigator","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The private ","type":"text"},{"type":"codeVoice","code":"R2LCPClient"},{"text":" library customized for your application ","type":"text"},{"identifier":"https:\/\/www.edrlab.org\/contact\/","overridingTitle":"is available from EDRLab","isActive":true,"type":"reference","overridingTitleInlineContent":[{"text":"is available from EDRLab","type":"text"}]},{"text":". They will provide instructions for integrating the ","type":"text"},{"type":"codeVoice","code":"R2LCPClient"},{"text":" framework into your application.","type":"text"}]}]}]},{"type":"heading","level":3,"text":"File formats","anchor":"File-formats"},{"type":"paragraph","inlineContent":[{"text":"Readium LCP specifies new file formats.","type":"text"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"File extension"}]}],[{"type":"paragraph","inlineContent":[{"text":"Media type","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/readium.org\/lcp-specs\/releases\/lcp\/latest.html#32-content-conformance","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".lcpl"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"application\/vnd.readium.lcp.license.v1.0+json"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/readium.org\/lcp-specs\/notes\/lcp-for-pdf.html","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".lcpdf"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"application\/pdf+lcp"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/readium.org\/lcp-specs\/notes\/lcp-for-audiobooks.html"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".lcpa"}]}],[{"type":"paragraph","inlineContent":[{"code":"application\/audiobook+lcp","type":"codeVoice"}]}]]]},{"content":[{"inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"EPUB files protected by LCP are supported without a special file extension or media type because EPUB accommodates any DRM scheme in its specification.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"text":"To support these formats in your application, you need to ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uniformtypeidentifiers\/defining_file_and_data_types_for_your_app","isActive":true},{"text":" as imported types.","type":"text"}]},{"type":"codeListing","code":["<dict>","    <key>UTImportedTypeDeclarations<\/key>","    <array>","        <dict>","            <key>UTTypeIdentifier<\/key>","            <string>org.readium.lcpl<\/string>","            <key>UTTypeConformsTo<\/key>","            <array>","                <string>public.content<\/string>","                <string>public.data<\/string>","                <string>public.json<\/string>","            <\/array>","            <key>UTTypeDescription<\/key>","            <string>LCP License Document<\/string>","            <key>UTTypeTagSpecification<\/key>","            <dict>","                <key>public.filename-extension<\/key>","                <array>","                    <string>lcpl<\/string>","                <\/array>","                <key>public.mime-type<\/key>","                <string>application\/vnd.readium.lcp.license.v1.0+json<\/string>","            <\/dict>","        <\/dict>","        <dict>","            <key>UTTypeIdentifier<\/key>","            <string>org.readium.lcpdf<\/string>","            <key>UTTypeConformsTo<\/key>","            <array>","                <string>public.content<\/string>","                <string>public.data<\/string>","                <string>public.archive<\/string>","                <string>public.zip-archive<\/string>","            <\/array>","            <key>UTTypeDescription<\/key>","            <string>LCP for PDF package<\/string>","            <key>UTTypeTagSpecification<\/key>","            <dict>","                <key>public.filename-extension<\/key>","                <array>","                    <string>lcpdf<\/string>","                <\/array>","                <key>public.mime-type<\/key>","                <string>application\/pdf+lcp<\/string>","            <\/dict>","        <\/dict>","        <dict>","            <key>UTTypeIdentifier<\/key>","            <string>org.readium.lcpa<\/string>","            <key>UTTypeConformsTo<\/key>","            <array>","                <string>public.content<\/string>","                <string>public.data<\/string>","                <string>public.archive<\/string>","                <string>public.zip-archive<\/string>","            <\/array>","            <key>UTTypeDescription<\/key>","            <string>LCP for Audiobooks package<\/string>","            <key>UTTypeTagSpecification<\/key>","            <dict>","                <key>public.filename-extension<\/key>","                <array>","                    <string>lcpa<\/string>","                <\/array>","                <key>public.mime-type<\/key>","                <string>application\/audiobook+lcp<\/string>","            <\/dict>","        <\/dict>","    <\/array>","<\/dict>"],"syntax":"xml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Next, declare the imported types as "},{"type":"reference","isActive":true,"identifier":"https:\/\/help.apple.com\/xcode\/mac\/current\/#\/devddd273fdd"},{"type":"text","text":" in the "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" to have your application listed in the “Open with…” dialogs."}]},{"type":"codeListing","code":["<dict>","    <key>CFBundleDocumentTypes<\/key>","    <array>","        <dict>","            <key>CFBundleTypeName<\/key>","            <string>LCP License Document<\/string>","            <key>CFBundleTypeRole<\/key>","            <string>Viewer<\/string>","            <key>LSItemContentTypes<\/key>","            <array>","                <string>org.readium.lcpl<\/string>","            <\/array>","        <\/dict>","        <dict>","            <key>CFBundleTypeName<\/key>","            <string>LCP for PDF package<\/string>","            <key>CFBundleTypeRole<\/key>","            <string>Viewer<\/string>","            <key>LSItemContentTypes<\/key>","            <array>","                <string>org.readium.lcpdf<\/string>","            <\/array>","        <\/dict>","        <dict>","            <key>CFBundleTypeName<\/key>","            <string>LCP for Audiobooks package<\/string>","            <key>CFBundleTypeRole<\/key>","            <string>Viewer<\/string>","            <key>LSItemContentTypes<\/key>","            <array>","                <string>org.readium.lcpa<\/string>","            <\/array>","        <\/dict>","    <\/array>","<\/dict>"],"syntax":"xml"},{"content":[{"type":"paragraph","inlineContent":[{"text":"[!TIP]","type":"text"},{"text":" ","type":"text"},{"text":"If EPUB is not included in your document types, now is a good time to add it.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"type":"heading","level":3,"text":"Allow insecure HTTP requests","anchor":"Allow-insecure-HTTP-requests"},{"type":"paragraph","inlineContent":[{"text":"A file required by the LCP library needs to be downloaded from an insecure HTTP location. You must authorize this download by adding the following to your ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" file:","type":"text"}]},{"type":"codeListing","code":["<key>NSAppTransportSecurity<\/key>","<dict>","    <key>NSExceptionDomains<\/key>","    <dict>","        <key>crl.edrlab.telesec.de<\/key>","        <dict>","            <key>NSExceptionAllowsInsecureHTTPLoads<\/key>","            <true\/>","        <\/dict>","    <\/dict>","<\/dict>"],"syntax":"xml"},{"type":"heading","level":2,"text":"Initializing the `LCPService`","anchor":"Initializing-the-LCPService"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ReadiumLCP"},{"type":"text","text":" offers an "},{"type":"codeVoice","code":"LCPService"},{"type":"text","text":" object that exposes its API. Since the "},{"type":"codeVoice","code":"ReadiumLCP"},{"type":"text","text":" package is not linked with "},{"type":"codeVoice","code":"R2LCPClient"},{"type":"text","text":", you need to create your own adapter when setting up the "},{"type":"codeVoice","code":"LCPService"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"LCPService"},{"type":"text","text":" expects repositories to store the opened licenses and passphrases. "},{"type":"codeVoice","code":"ReadiumLCP"},{"type":"text","text":" provides built-in Keychain-based implementations that store data securely in the iOS\/macOS Keychain. Unlike database-based storage, Keychain data persists across app reinstalls and can optionally be synchronized across the user’s devices via iCloud Keychain."}]},{"type":"codeListing","code":["import R2LCPClient","import ReadiumLCP","","let httpClient = DefaultHTTPClient()","","let assetRetriever = AssetRetriever(","    httpClient: httpClient",")","","let lcpService = LCPService(","    client: LCPClientAdapter(),","    licenseRepository: LCPKeychainLicenseRepository(),","    passphraseRepository: LCPKeychainPassphraseRepository(),","    assetRetriever: assetRetriever,","    httpClient: httpClient",")","","\/\/\/ Facade to the private R2LCPClient.framework.","class LCPClientAdapter: ReadiumLCP.LCPClient {","    func createContext(jsonLicense: String, hashedPassphrase: LCPPassphraseHash, pemCrl: String) throws -> LCPClientContext {","        try R2LCPClient.createContext(jsonLicense: jsonLicense, hashedPassphrase: hashedPassphrase, pemCrl: pemCrl)","    }","","    func decrypt(data: Data, using context: LCPClientContext) -> Data? {","        R2LCPClient.decrypt(data: data, using: context as! DRMContext)","    }","","    func findOneValidPassphrase(jsonLicense: String, hashedPassphrases: [LCPPassphraseHash]) -> LCPPassphraseHash? {","        R2LCPClient.findOneValidPassphrase(jsonLicense: jsonLicense, hashedPassphrases: hashedPassphrases)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To disable iCloud synchronization, pass "},{"code":"synchronizable: false","type":"codeVoice"},{"text":" when creating the repositories.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You may also implement your own persistence layer by conforming to ","type":"text"},{"type":"codeVoice","code":"LCPLicenseRepository"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"LCPPassphraseRepository"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Acquiring a publication from a License Document (LCPL)","anchor":"Acquiring-a-publication-from-a-License-Document-LCPL"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Users need to import a License Document into your application to download the protected publication ("},{"code":".epub","type":"codeVoice"},{"type":"text","text":", "},{"code":".lcpdf","type":"codeVoice"},{"type":"text","text":", or "},{"code":".lcpa","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"LCPService","type":"codeVoice"},{"text":" offers an API to retrieve the full publication from an LCPL on the filesystem.","type":"text"}]},{"type":"codeListing","code":["let result = await lcpService.acquirePublication(","    from: .file(lcplURL),","    onProgress: { progress in","        switch progress {","            case .indefinite:","                \/\/ Display an activity indicator.","            case .percent(let percent):","                \/\/ Display a progress bar with percent from 0 to 1.","        }","    }",")","","switch result {","case let .success(publication):","    \/\/ Import the `publication.localURL` file as any publication.","case let .failure(error):","    \/\/ Display the error message.","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"After the download is completed, import the ","type":"text"},{"type":"codeVoice","code":"publication.localURL"},{"text":" file into the bookshelf like any other publication file.","type":"text"}]},{"type":"heading","level":2,"text":"Opening a publication protected with LCP","anchor":"Opening-a-publication-protected-with-LCP"},{"type":"heading","level":3,"text":"Initializing the `PublicationOpener`","anchor":"Initializing-the-PublicationOpener"},{"type":"paragraph","inlineContent":[{"text":"A publication protected with LCP can be opened using the ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":" component, just like a non-protected publication. However, you must provide a ","type":"text"},{"identifier":"https:\/\/readium.org\/architecture\/proposals\/006-content-protection.html","isActive":true,"type":"reference"},{"text":" implementation when initializing the ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":" to enable LCP. Luckily, ","type":"text"},{"code":"LCPService","type":"codeVoice"},{"text":" has you covered.","type":"text"}]},{"type":"codeListing","code":["let httpClient = DefaultHTTPClient()","","let authentication = LCPDialogAuthentication()","","let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: AssetRetriever(httpClient: httpClient),","        pdfFactory: DefaultPDFDocumentFactory()","    ),","    contentProtections: [","        lcpService.contentProtection(with: authentication)","    ]",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"An LCP package is secured with a ","type":"text"},{"inlineContent":[{"type":"text","text":"user passphrase"}],"type":"emphasis"},{"text":" for decrypting the content. The ","type":"text"},{"code":"LCPAuthenticating","type":"codeVoice"},{"text":" protocol used by ","type":"text"},{"code":"LCPService.contentProtection(with:)","type":"codeVoice"},{"text":" provides the passphrase when needed. You can use the default UIKit ","type":"text"},{"code":"LCPDialogAuthentication","type":"codeVoice"},{"text":" which displays a pop-up to enter the passphrase, or implement your own method for passphrase retrieval. If your application is built using SwiftUI, ","type":"text"},{"isActive":true,"type":"reference","identifier":"#using-the-swiftui-lcp-authentication-dialog"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"The user will be prompted once per passphrase since ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" stores known passphrases on the device.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"type":"heading","level":3,"text":"Opening the publication","anchor":"Opening-the-publication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You are now ready to open the publication file with your "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":" instance."}]},{"type":"codeListing","code":["\/\/ Retrieve an `Asset` to access the file content.","let url = FileURL(path: \"\/path\/to\/lcp-protected-book.epub\", isDirectory: false)","let asset = try await assetRetriever.retrieve(url: url).get()"," ","\/\/ Open a `Publication` from the `Asset`.","let result = await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: hostViewController",")","","switch result {","case .success(let publication):","    \/\/ Import or present the publication.","case .failure(let error):","    \/\/ Present the error.","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"allowUserInteraction","type":"codeVoice"},{"type":"text","text":" and "},{"code":"sender","type":"codeVoice"},{"type":"text","text":" arguments are forwarded to the "},{"code":"LCPAuthenticating","type":"codeVoice"},{"type":"text","text":" implementation when the passphrase is unknown. "},{"code":"LCPDialogAuthentication","type":"codeVoice"},{"type":"text","text":" shows a pop-up only if "},{"code":"allowUserInteraction","type":"codeVoice"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":", using the "},{"code":"sender","type":"codeVoice"},{"type":"text","text":" as the pop-up’s host "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When importing the publication to the bookshelf, set "},{"type":"codeVoice","code":"allowUserInteraction"},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" as you don’t need the passphrase for accessing the publication metadata and cover. If you intend to present the publication using a Navigator, set "},{"type":"codeVoice","code":"allowUserInteraction"},{"type":"text","text":" to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" as decryption will be required."}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[!TIP]","type":"text"},{"text":" ","type":"text"},{"text":"To check if an asset is protected with LCP before opening it, you can use ","type":"text"},{"code":"asset.format.conformsTo(.lcp)","type":"codeVoice"},{"text":".","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"type":"heading","level":3,"text":"Using the opened `Publication`","anchor":"Using-the-opened-Publication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After obtaining a "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" instance, you can access the publication’s metadata to import it into the user’s bookshelf. The user passphrase is not needed for reading the metadata or cover."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, if you want to display the publication with a Navigator, verify it is not restricted. It could be restricted if the user passphrase is unknown or if the license is no longer valid (e.g., expired loan, revoked purchase, etc.)."}]},{"type":"codeListing","code":["if publication.isRestricted {","    if let error = publication.protectionError as? LCPError {","        \/\/ The user is not allowed to open the publication. You should display the error.","    } else {","        \/\/ We don't have the user passphrase.","        \/\/ You may use `publication` to access its metadata, but not to render its content.","    }","} else {","    \/\/ The publication is not restricted, you may render it with a Navigator component.","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Streaming an LCP protected package","anchor":"Streaming-an-LCP-protected-package"},{"type":"paragraph","inlineContent":[{"text":"If the server hosting the LCP protected package supports the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/httpwg.org\/specs\/rfc9110.html#HEAD"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/httpwg.org\/specs\/rfc7233.html"},{"text":", it is possible to stream directly an LCP protected publication from a License Document (","type":"text"},{"type":"codeVoice","code":".lcpl"},{"text":") file, without downloading the whole publication first.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Simply open the License Document directly using the "},{"code":"PublicationOpener","type":"codeVoice"},{"type":"text","text":". Make sure you provide an "},{"code":"HTTPClient","type":"codeVoice"},{"type":"text","text":" (or an "},{"code":"HTTPResourceFactory","type":"codeVoice"},{"type":"text","text":" for additional customization) to the "},{"code":"AssetRetriever","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","code":["\/\/ Instantiate the required components.","let httpClient = DefaultHTTPClient()","let assetRetriever = AssetRetriever(httpClient: httpClient)","let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever","    ),","    contentProtections: [","        lcpService.contentProtection(with: LCPDialogAuthentication()),","    ]",")","","\/\/ Retrieve an `Asset` to access the LCPL content.","let url = FileURL(path: \"\/path\/to\/license.lcpl\", isDirectory: false)","let asset = try await assetRetriever.retrieve(url: url).get()"," ","\/\/ Open a `Publication` from the LCPL `Asset`.","let publication = try await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: hostViewController",").get()","    ","print(\"Opened \\(publication.metadata.title)\")"],"syntax":"swift"},{"type":"heading","level":2,"text":"Obtaining information on an LCP license","anchor":"Obtaining-information-on-an-LCP-license"},{"type":"paragraph","inlineContent":[{"text":"An LCP License Document contains metadata such as its expiration date, the remaining number of characters to copy and the user name. You can access this information using an ","type":"text"},{"type":"codeVoice","code":"LCPLicense"},{"text":" object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"LCPService"},{"type":"text","text":" to retrieve the "},{"type":"codeVoice","code":"LCPLicense"},{"type":"text","text":" instance for a publication."}]},{"type":"codeListing","code":["let result = await lcpService.retrieveLicense(","    from: asset,","    authentication: LCPDialogAuthentication(),","    allowUserInteraction: true,","    sender: hostViewController",")","","switch result {","case .success(let lcpLicense):","    if let user = lcpLicense.license.user.name {","        print(\"The publication was acquired by \\(user)\")","    }","    if let endDate = lcpLicense.license.rights.end {","        print(\"The loan expires on \\(endDate)\")","    }","    if let copyLeft = await lcpLicense.charactersToCopyLeft() {","        print(\"You can copy up to \\(copyLeft) characters remaining.\")","    }","case .failure(let error):","    \/\/ Display the error.","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you have already opened a ","type":"text"},{"code":"Publication","type":"codeVoice"},{"text":" with the ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":", you can directly obtain the ","type":"text"},{"code":"LCPLicense","type":"codeVoice"},{"text":" using ","type":"text"},{"code":"publication.lcpLicense","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Managing a loan","anchor":"Managing-a-loan"},{"type":"paragraph","inlineContent":[{"text":"Readium LCP allows borrowing publications for a specific period. Use the ","type":"text"},{"type":"codeVoice","code":"LCPLicense"},{"text":" object to manage a loan and retrieve its end date using ","type":"text"},{"type":"codeVoice","code":"lcpLicense.license.rights.end"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Returning a loan","anchor":"Returning-a-loan"},{"type":"paragraph","inlineContent":[{"text":"Some loans can be returned before the end date. You can confirm this by using ","type":"text"},{"code":"lcpLicense.canReturnPublication","type":"codeVoice"},{"text":". To return the publication, execute:","type":"text"}]},{"type":"codeListing","code":["let result = await lcpLicense.returnPublication()","switch result {","case .success:","    \/\/ The publication was returned.","case .failure(let error):","    \/\/ Present the error.","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Renewing a loan","anchor":"Renewing-a-loan"},{"type":"paragraph","inlineContent":[{"text":"The loan end date may also be extended. You can confirm this by using ","type":"text"},{"code":"lcpLicense.canRenewLoan","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Readium LCP supports "},{"isActive":true,"type":"reference","identifier":"https:\/\/readium.org\/lcp-specs\/releases\/lsd\/latest#35-renewing-a-license"},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Programmatic: You show your own user interface."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Interactive: You display a web view, and the Readium LSD server manages the renewal for you."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to support both interactions by implementing the "},{"code":"LCPRenewDelegate","type":"codeVoice"},{"type":"text","text":" protocol. A default implementation is available with "},{"code":"LCPDefaultRenewDelegate","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","code":["let result = await lcpLicense.renewLoan(","    with: LCPDefaultRenewDelegate(","        presentingViewController: hostViewController","    )",")","","switch result {","case .success:","    \/\/ The publication was renewed.","case let .failure(error):","    \/\/ Display the error.","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Handling `LCPError`","anchor":"Handling-LCPError"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The APIs may fail with an "},{"type":"codeVoice","code":"LCPError"},{"type":"text","text":". These errors "},{"type":"strong","inlineContent":[{"text":"must","type":"text"}]},{"type":"text","text":" be displayed to the user with a suitable message."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For an example, "},{"type":"reference","identifier":"https:\/\/github.com\/readium\/swift-toolkit\/blob\/3.0.0\/TestApp\/Sources\/App\/Readium.swift#L221","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Using the SwiftUI LCP Authentication dialog","anchor":"Using-the-SwiftUI-LCP-Authentication-dialog"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your application is built using SwiftUI, you cannot use "},{"type":"codeVoice","code":"LCPDialogAuthentication"},{"type":"text","text":" because it requires a UIKit view controller as its host. Instead, use an "},{"type":"codeVoice","code":"LCPObservableAuthentication"},{"type":"text","text":" combined with our SwiftUI "},{"type":"codeVoice","code":"LCPDialog"},{"type":"text","text":" presented as a sheet."}]},{"type":"codeListing","code":["@main","struct MyApp: App {","    private let lcpService: LCPService","    private let publicationOpener: PublicationOpener","","    @StateObject private var lcpAuthentication: LCPObservableAuthentication","","    init() {","        \/\/ Create an `LCPObservableAuthentication` which will be used","        \/\/ to initialize the `LCPContentProtection`.","        \/\/","        \/\/ With SwiftUI, it must be stored in a `@StateObject` property","        \/\/ to observe the authentication requests.","        let lcpAuthentication = LCPObservableAuthentication()","        _lcpAuthentication = StateObject(wrappedValue: lcpAuthentication)","","        lcpService = LCPService(...)","","        publicationOpener = PublicationOpener(","            ...,","            contentProtections: [","                lcpService.contentProtection(with: lcpAuthentication)","            ]","        )","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","                \/\/ You can present an `LCPDialog` when the `LCPObservableAuthentication`","                \/\/ `request` property is updated.","                .sheet(item: $lcpAuthentication.request) {","                    LCPDialog(request: $0)","                }","            }","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"references":{"https://www.w3.org/TR/epub-a11y-11":{"titleInlineContent":[{"text":"EPUB Accessibility","type":"text"}],"type":"link","identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","url":"https:\/\/www.w3.org\/TR\/epub-a11y-11","title":"EPUB Accessibility"},"https://www.edrlab.org/contact/":{"url":"https:\/\/www.edrlab.org\/contact\/","identifier":"https:\/\/www.edrlab.org\/contact\/","title":"EDRLab","type":"link","titleInlineContent":[{"text":"EDRLab","type":"text"}]},"https://httpwg.org/specs/rfc7233.html":{"titleInlineContent":[{"text":"HTTP Range requests","type":"text"}],"type":"link","identifier":"https:\/\/httpwg.org\/specs\/rfc7233.html","url":"https:\/\/httpwg.org\/specs\/rfc7233.html","title":"HTTP Range requests"},"doc://Readium/documentation/Readium/TTS":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","type":"topic","role":"article","url":"\/documentation\/readium\/tts","kind":"article","title":"Text-to-speech","abstract":[]},"doc://Readium/documentation/Readium/Accessibility":{"abstract":[{"text":"Some publications declare their accessibility features and limitations as metadata which broadly mirror the ","type":"text"},{"identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","type":"reference","isActive":true},{"text":" specification.","type":"text"}],"title":"Accessibility","type":"topic","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Accessibility","url":"\/documentation\/readium\/accessibility","kind":"article"},"https://github.com/readium/swift-toolkit/blob/3.0.0/TestApp/Sources/App/Readium.swift#L221":{"url":"https:\/\/github.com\/readium\/swift-toolkit\/blob\/3.0.0\/TestApp\/Sources\/App\/Readium.swift#L221","identifier":"https:\/\/github.com\/readium\/swift-toolkit\/blob\/3.0.0\/TestApp\/Sources\/App\/Readium.swift#L221","title":"take a look at the Test App","