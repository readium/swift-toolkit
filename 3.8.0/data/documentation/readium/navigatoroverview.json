","identifier":"doc:\/\/Readium\/documentation\/Readium\/Navigator","title":"Navigator"},"Decorations.md":{"identifier":"Decorations.md","title":"Decorations guide","titleInlineContent":[{"text":"Decorations guide","type":"text"}],"url":"Decorations.md","type":"link"},"doc://Readium/documentation/Readium/Preferences":{"title":"Configuring the Navigator","abstract":[{"type":"text","text":"Take a look at the "},{"type":"reference","isActive":true,"identifier":"..\/Migration%20Guide.md"},{"type":"text","text":" if you are already using the legacy EPUB settings."}],"url":"\/documentation\/readium\/preferences","kind":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Preferences","role":"article"},"doc://Readium/documentation/Readium/Getting-Started":{"title":"Getting started","url":"\/documentation\/readium\/getting-started","type":"topic","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started","kind":"article","abstract":[{"text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics.","type":"text"}]},"doc://Readium/documentation/Readium/Migration-Guide":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","type":"topic","role":"article","url":"\/documentation\/readium\/migration-guide","kind":"article","title":"Migration Guide","abstract":[{"type":"text","text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file."}]},"doc://Readium/documentation/Readium/Decorations":{"url":"\/documentation\/readium\/decorations","kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Decorations","title":"Decorations","abstract":[{"type":"text","text":"The Decoration API lets you overlay visual elements on publication content – highlights, search result mar