{"primaryContentSections":[{"kind":"content","content":[{"text":"SwiftUI wrapper for a Navigator’s `UIViewController`","type":"heading","level":2,"anchor":"SwiftUI-wrapper-for-a-Navigators-UIViewController"},{"inlineContent":[{"type":"text","text":"Here is a basic example of a "},{"code":"UIViewControllerRepresentable","type":"codeVoice"},{"type":"text","text":" implementation that hosts a Navigator."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/\/ SwiftUI wrapper for the `ReaderViewController`.","struct ReaderViewControllerWrapper: UIViewControllerRepresentable {","    let viewController: ReaderViewController","","    func makeUIViewController(context: Context) -> ReaderViewController {","        viewController","    }","","    func updateUIViewController(_ uiViewController: ReaderViewController, context: Context) {}","}","","\/\/\/ Host view controller for a Readium Navigator.","class ReaderViewController: UIViewController {","","    \/\/\/ View model provided by your application.","    private let viewModel: ReaderViewModel","    ","    \/\/\/ Readium Navigator instance.","    private let navigator: Navigator & UIViewController","","    init(viewModel: ReaderViewModel, navigator: Navigator & UIViewController) {","        self.viewModel = viewModel","        self.navigator = navigator","","        super.init(nibName: nil, bundle: nil)","    }","","    @available(*, unavailable)","    required init?(coder: NSCoder) {","        fatalError(\"init?(coder: NSCoder) not implemented\")","    }","","    override func viewDidLoad() {","        super.viewDidLoad()","","        addChild(navigator)","        navigator.view.frame = view.bounds","        navigator.view.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(navigator.view)","        navigator.didMove(toParent: self)","    }","","    \/\/\/ Handler for a custom editing action.","    @objc func makeHighlight(_ sender: Any) {","        viewModel.makeHighlight()","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Note that we could use a ","type":"text"},{"code":"Navigator","type":"codeVoice"},{"text":" instance directly, without a parent ","type":"text"},{"code":"ReaderViewController","type":"codeVoice"},{"text":". However, a host view controller is necessary if you want to use custom text selection menu items and capture events in the UIKit responder chain. For instance, when configuring your EPUB Navigator with:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var config = EPUBNavigatorViewController.Configuration()","config.editingActions.append(","    EditingAction(","        title: \"Highlight\",","        action: #selector(makeHighlight)","    )",")","","let navigator = try EPUBNavigatorViewController(","    publication: publication,","    initialLocation: locator,","    config: config,","    ...",")"],"type":"codeListing"},{"text":"Embedding the `ReaderViewControllerWrapper` in a SwiftUI view","type":"heading","level":2,"anchor":"Embedding-the-ReaderViewControllerWrapper-in-a-SwiftUI-view"},{"syntax":"swift","code":["struct ReaderView: View {","    ","    \/\/\/ View model provided by your application.","    @ObservedObject var viewModel: ReaderViewModel","","    let viewControllerWrapper: ReaderViewControllerWrapper","","    var body: some View {","        viewControllerWrapper","            .frame(maxWidth: .infinity, maxHeight: .infinity)","            .ignoresSafeArea(.all)","            .navigationTitle(viewModel.book.title)","            .navigationBarTitleDisplayMode(.inline)","            .navigationBarHidden(viewModel.isFullscreen)","            .statusBarHidden(viewModel.isFullscreen)","    }","}"],"type":"codeListing"},{"text":"Assembling the Navigator and SwiftUI objects","type":"heading","level":2,"anchor":"Assembling-the-Navigator-and-SwiftUI-objects"},{"inlineContent":[{"type":"text","text":"Now, let’s construct an EPUB navigator and assemble the SwiftUI view hierarchy to bring all the pieces together."}],"type":"paragraph"},{"syntax":"swift","code":["var config = EPUBNavigatorViewController.Configuration()","config.editingActions.append(","    EditingAction(","        title: \"Highlight\",","        action: #selector(highlightSelection)","    )",")","","let navigator = try EPUBNavigatorViewController(","    publication: publication,","    initialLocation: locator,","    config: config,","    ...",")","","\/\/ View model provided by your application.","let viewModel = ReaderViewModel()","","let view = ReaderView(","    viewModel: viewModel,","    viewControllerWrapper: ReaderViewControllerWrapper(","        viewController: ReaderViewController(","            viewModel: viewModel,","            navigator: navigator","        )","    )",")"],"type":"codeListing"},{"text":"Handling touch and keyboard events","type":"heading","level":2,"anchor":"Handling-touch-and-keyboard-events"},{"inlineContent":[{"text":"Use the navigator’s input observer API to handle touch and keyboard events. Avoid using SwiftUI touch modifiers, as they will prevent the user from interacting with the book.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Example: Toggle UI visibility when the user taps the navigator.","navigator.addObserver(.tap { [weak viewModel] _ in","    viewModel?.toggleUIVisibility()","    return true","})"],"type":"codeListing"},{"inlineContent":[{"text":"See the ","type":"text"},{"isActive":true,"type":"reference","identifier":"Input.md"},{"text":" for more details on handling user input.","type":"text"}],"type":"paragraph"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview"]]},"abstract":[{"type":"text","text":"The Navigator is built with UIKit and provides "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" implementations. Nevertheless, you can integrate them into a SwiftUI view hierarchy using Apple’s "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/uiviewrepresentable","isActive":true},{"type":"text","text":"."}],"seeAlsoSections":[{"title":"Essentials","anchor":"Essentials","generated":true,"identifiers":["doc:\/\/Readium\/documentation\/Readium\/Navigator","doc:\/\/Readium\/documentation\/Readium\/Preferences","doc:\/\/Readium\/documentation\/Readium\/Input","doc:\/\/Readium\/documentation\/Readium\/Highlights","doc:\/\/Readium\/documentation\/Readium\/Decorations","doc:\/\/Readium\/documentation\/Readium\/EPUB-Fonts"]}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"article","title":"Integrating the Navigator with SwiftUI","roleHeading":"Article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Readium\/documentation\/Readium\/SwiftUI"},"references":{"doc://Readium/documentation/Readium/EPUB-Fonts":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/EPUB-Fonts","abstract":[{"type":"text","text":"Readium allows users to customize the font family used to render a reflowable EPUB, by changing the "},{"type":"reference","isActive":true,"identifier":"Preferences.md"},{"type":"text","text":"."}],"role":"article","type":"topic","url":"\/documentation\/readium\/epub-fonts","title":"Font families in the EPUB navigator","kind":"article"},"doc://Readium/documentation/Readium/NavigatorOverview":{"type":"topic","title":"Navigator Overview","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","role":"article","abstract":[{"type":"text","text":"Learn about the architecture, configuration, and usage of the Readium Navigator."}],"url":"\/documentation\/readium\/navigatoroverview","kind":"article"},"Input.md":{"titleInlineContent":[{"type":"text","text":"Input guide"}],"title":"Input guide","type":"link","identifier":"Input.md","url":"Input.md"},"doc://Readium/documentation/Readium/Highlights":{"type":"topic","title":"Implementing Highlights","url":"\/documentation\/readium\/highlights","role":"article","abstract":[{"type":"text","text":"Highlighting lets users mark up passages in a publication for later reference - a core feature of any reading app. In Readium, highlights are built on top of the "},{"type":"strong","inlineContent":[{"type":"text","text":"Decoration API"}]},{"type":"text","text":". If you want to understand that API in depth or build a custom decoration style, see the "},{"type":"reference","identifier":"Decorations.md","isActive":true},{"type":"text","text":"."}],"kind":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Highlights"},"doc://Readium/documentation/Readium/Input":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Input","kind":"article","abstract":[{"type":"text","text":"In visual publications like EPUB or PDF, users can interact with the "},{"type":"codeVoice","code":"VisualNavigator"},{"type":"text","text":" instance using gestures, a keyboard, a mouse, a pencil, or a trackpad. When the publication does not override user input events, you may want to intercept them to trigger actions in your user interface. For example, you can turn pages or toggle the navigation bar on taps, or open a bookmarks screen when pressing the Command-Shift-D hotkey."}],"title":"Observing user input","role":"article","type":"topic","url":"\/documentation\/readium\/input"},"doc://Readium/documentation/Readium/Navigator":{"type":"topic","role":"article","abstract":[{"type":"text","text":"You can use a Readium Navigator to present the publication to the user. The "},{"type":"codeVoice","code":"Navigator"},{"type":"text","text":" renders resources on the screen and offers APIs and user interactions for navigating the contents."}],"url":"\/documentation\/readium\/navigator","kind":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Navigator","title":"Navigator"},"doc://Readium/documentation/Readium":{"identifier":"doc:\/\/Readium\/documentation\/Readium","url":"\/documentation\/readium","role":"collection","title":"Readium","type":"topic","kind":"article","abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}]},"Preferences.md":{"titleInlineContent":[{"type":"text","text":"EPUB navigator preferences"}],"title":"EPUB navigator preferences","type":"link","identifier":"Preferences.md","url":"Preferences.md"},"doc://Readium/documentation/Readium/Decorations":{"url":"\/documentation\/readium\/decorations","kind":"article","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Decorations","title":"Decorations","abstract":[{"type":"text","text":"The Decoration API lets you overlay visual elements on publication content – highlights, search result markers, TTS playback indicators, page-number labels in the margin, and more. For the common case of implementing user highlights, see the "},{"isActive":true,"type":"reference","identifier":"Highlights.md"},{"type":"text","text":"."}],"type":"topic"},"doc://Readium/documentation/Readium/Preferences":{"title":"Configuring the Navigator","abstract":[{"type":"text","text":"Take a look at the "},{"type":"reference","isActive":true,"identifier":"..\/Migration%20Guide.md"},{"type":"text","text":" if you are already using the legacy EPUB settings."}],"url":"\/documentation\/readium\/preferences","kind":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Preferences","role":"article"},"../Migration%20Guide.md":{"url":"..\/Migration%20Guide.md","titleInlineContent":[{"type":"text","text":"migration guide"}],"type":"link","identifier":"..\/Migration%20Guide.md","title":"migration guide"},"Decorations.md":{"type":"link","title":"Decorations guide","url":"Decorations.md","titleInlineContent":[{"text":"Decorations guide","type":"text"}],"identifier":"Decorations.md"},"Highlights.md":{"url":"Highlights.md","titleInlineContent":[{"type":"text","text":"Highlighting guide"}],"type":"link","identifier":"Highlights.md","title":"Highlighting guide"}}}