{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"seeAlsoSections":[{"generated":true,"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"]}],"kind":"article","identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","interfaceLanguage":"swift"},"metadata":{"role":"article","roleHeading":"Article","title":"Opening a publication"},"abstract":[{"type":"text","text":"To open a publication with Readium, you need to instantiate a couple of components: an "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" and a "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":"."}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"AssetRetriever","text":"`AssetRetriever`"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" grants access to the content of an asset located at a given URL, such as a publication package, manifest, or LCP license."}]},{"type":"heading","level":3,"anchor":"Constructing-an-AssetRetriever","text":"Constructing an `AssetRetriever`"},{"type":"paragraph","inlineContent":[{"text":"You can create an instance of ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" with:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"code":"HTTPClient","type":"codeVoice"},{"text":" to enable the toolkit to perform HTTP requests and sup