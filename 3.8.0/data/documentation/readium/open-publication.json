:"Asset"},{"type":"text","text":". This will improve performance, especially with HTTP URL schemes."}]},{"code":["let mediaType = asset.format.mediaType","","\/\/ Speed up the retrieval with a known media type.","let result = await assetRetriever.retrieve(url: url, mediaType: mediaType)"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"`PublicationOpener`","anchor":"PublicationOpener"},{"inlineContent":[{"code":"PublicationOpener","type":"codeVoice"},{"text":" builds a ","type":"text"},{"code":"Publication","type":"codeVoice"},{"text":" object from an ","type":"text"},{"code":"Asset","type":"codeVoice"},{"text":" using:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"PublicationParser"},{"type":"text","text":" to parse the asset structure and publication metadata."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"DefaultPublicationParser"},{"text":" handles all the formats supported by Readium out of the box.","type":"text"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional list of "},{"type":"codeVoice","code":"ContentProtection"},{"type":"text","text":" to decrypt DRM-protected publications."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If you support Readium LCP, you can get one from the "},{"code":"LCPService","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}]}]}]},{"code":["let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever,","        pdfFactory: DefaultPDFDocumentFactory()","    ),","    contentProtections: [","        lcpService.contentProtection(with: LCPDialogAuthentication())","    ]",")"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Opening a `Publication`","anchor":"Opening-a-Publication"},{"inlineContent":[{"type":"text","text":"Now that you have a "},{"code":"PublicationOpener","type":"codeVoice"},{"type":"text","text":" ready, you can use it to create a "},{"code":"Publication","type":"codeVoice"},{"type":"text","text":" from an "},{"code":"Asset","type":"codeVoice"},{"type":"text","text":" that was previously obtained using the "},{"code":"AssetRetriever","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"allowUserInteraction"},{"text":" parameter is useful when supporting Readium LCP. When enabled and using a ","type":"text"},{"type":"codeVoice","code":"LCPDialogAuthentication"},{"text":", the toolkit will prompt the user if the passphrase is missing.","type":"text"}],"type":"paragraph"},{"code":["let result = await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: sender",")"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Supporting additional formats or URL schemes","anchor":"Supporting-additional-formats-or-URL-schemes"},{"inlineContent":[{"code":"DefaultPublicationParser","type":"codeVoice"},{"type":"text","text":" accepts additional parsers. You also have the option to use your own parser list by using "},{"code":"CompositePublicationParser","type":"codeVoice"},{"type":"text","text":" or create your own "},{"code":"PublicationParser","type":"codeVoice"},{"type":"text","text":" for a fully customized parsing resolution strategy."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"code":"AssetRetriever","type":"codeVoice"},{"type":"text","text":" offers an additional constructor that provides greater extensibility options, using:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"Re