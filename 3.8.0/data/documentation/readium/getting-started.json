{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"sections":[],"metadata":{"title":"Getting started","roleHeading":"Article","role":"article"},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"Readium offers only low-level tools. You are responsible for creating a user interface for reading and managing books, as well as a data layer to store the user’s publications. The Test App is an example of such integration.","type":"text"}],"type":"paragraph"}]},{"text":"Design principles","anchor":"Design-principles","type":"heading","level":2},{"inlineContent":[{"text":"The toolkit has been designed following these core tenets:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modular"}]},{"type":"text","text":": It is divided into separate modules that can be used independently."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Extensible"}]},{"type":"text","text":": Integrators should be able to support a custom DRM, publication format or inject their own stylesheets without modifying the toolkit itself."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Opiniated","type":"text"}]},{"type":"text","text":": We adhere to open standards but sometimes interpret them for practicality."}],"type":"paragraph"}]}]},{"text":"Packages","anchor":"Packages","type":"heading","level":2},{"text":"Main packages","anchor":"Main-packages","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ReadiumShared"},{"type":"text","text":" contains shared "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" models and utilities."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ReadiumStreamer"},{"type":"text","text":" parses publication files (e.g. an EPUB) into a "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" object."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"Navigator\/Navigator.md"},{"type":"text","text":"."}]}]}]},{"text":"Specialized packages","anchor":"Specialized-packages","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ReadiumOPDS"},{"text":" parses ","type":"text"},{"identifier":"https:\/\/opds.io","isActive":true,"type":"reference"},{"text":" (both OPDS 1 and 2).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"Readium%20LCP.md","isActive":true},{"type":"text","text":"."}]}]}]},{"text":"Adapters to third-party dependencies","anchor":"Adapters-to-third-party-dependencies","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ReadiumAdapterGCDWebServer"},{"text":" provides an HTTP server built with ","type":"text"},{"identifier":"https:\/\/github.com\/swisspol\/GCDWebServer","isActive":true,"type":"reference"},{"text":", used by the PDF navigator.","type":"text"}]}]}]},{"text":"Overview of the shared models (`ReadiumShared`)","anchor":"Overview-of-the-shared-models-ReadiumShared","type":"heading","level":2},{"inlineContent":[{"text":"The Readium toolkit provides models used as exchange types between packages.","type":"text"}],"type":"paragraph"},{"text":"Publication models","anchor":"Publication-models","type":"heading","level":3},{"text":"Publication","anchor":"Publication","type":"heading","level":4},{"inlineContent":[{"code":"Publication","type":"codeVoice"},{"text":" and its sub-components represent a single publication – ebook, audiobook or comic. It is loosely based on the ","type":"text"},{"identifier":"https:\/\/readium.org\/webpub-manifest\/","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A "},{"code":"Publication","type":"codeVoice"},{"type":"text","text":" instance:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"holds the metadata of a publication, such as its author or table of contents,","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"allows to read the contents of a publication, e.g. XHTML or audio resources,","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"provides additional services, for example content extraction or text search."}]}]}]},{"text":"Link","anchor":"Link","type":"heading","level":4},{"inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"https:\/\/readium.org\/webpub-manifest\/#24-the-link-object"},{"type":"text","text":" holds a pointer (URL) to a resource or service along with additional metadata, such as its media type or title."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" contains several "},{"type":"codeVoice","code":"Link"},{"type":"text","text":" collections, for example:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"readingOrder","type":"codeVoice"},{"text":" lists the publication resources arranged in the order they should be read.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"resources"},{"type":"text","text":" contains secondary resources necessary for rendering the "},{"type":"codeVoice","code":"readingOrder"},{"type":"text","text":", such as an image or a font file."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"tableOfContents"},{"type":"text","text":" represents the table of contents as a tree of "},{"type":"codeVoice","code":"Link"},{"type":"text","text":" objects."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"links"},{"text":" exposes additional resources, such as a canonical link to the manifest or a search web service.","type":"text"}]}]}]},{"text":"Locator","anchor":"Locator","type":"heading","level":4},{"inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"https:\/\/readium.org\/architecture\/models\/locators\/","type":"reference"},{"text":" represents a precise location in a publication resource in a format that can be stored and shared across reading systems. It is more accurate than a ","type":"text"},{"code":"Link","type":"codeVoice"},{"text":" and contains additional information about the location, e.g. progression percentage, position or textual context.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"Locator","type":"codeVoice"},{"type":"text","text":" objects are used for various features, including:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"reporting the current progression in the publication","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"saving bookmarks, highlights and annotations"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"navigating search results"}],"type":"paragraph"}]}]},{"text":"Data models","anchor":"Data-models","type":"heading","level":3},{"text":"Asset","anchor":"Asset","type":"heading","level":4},{"inlineContent":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"Asset"},{"text":" represents a single file or package and provides access to its content. There are two types of ","type":"text"},{"type":"codeVoice","code":"Asset"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"ContainerAsset","type":"codeVoice"},{"text":" for packages which contains several resources, such as a ZIP archive.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ResourceAsset"},{"type":"text","text":" for accessing a single resource, such as a JSON or PDF file."}]}]}]},{"inlineContent":[{"type":"codeVoice","code":"Asset"},{"type":"text","text":" instances are obtained through an "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"You can use the ","type":"text"},{"type":"codeVoice","code":"asset.format"},{"text":" to identify the media type and capabilities of the asset.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["if asset.format.conformsTo(.lcp) {","    \/\/ The asset is protected with LCP.","}","if asset.format.conformsTo(.epub) {","    \/\/ The asset represents an EPUB publication.","}"]},{"text":"Resource","anchor":"Resource","type":"heading","level":4},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"Resource"},{"type":"text","text":" provides read access to a single resource, such as a file or an entry in an archive."}],"type":"paragraph"},{"inlineContent":[{"code":"Resource","type":"codeVoice"},{"text":" instances are usually created by a ","type":"text"},{"code":"ResourceFactory","type":"codeVoice"},{"text":". The toolkit ships with various implementations supporting different data access protocols such as local files or HTTP.","type":"text"}],"type":"paragraph"},{"text":"Container","anchor":"Container","type":"heading","level":4},{"inlineContent":[{"text":"A ","type":"text"},{"code":"Container","type":"codeVoice"},{"text":" provides read access to a collection of resources. ","type":"text"},{"code":"Container","type":"codeVoice"},{"text":" instances representing an archive are usually created by an ","type":"text"},{"code":"ArchiveOpener","type":"codeVoice"},{"text":". The toolkit ships with a ","type":"text"},{"code":"ZIPArchiveOpener","type":"codeVoice"},{"text":" supporting both local and remote (HTTP) ZIP files.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"Publication"},{"text":" objects internally use a ","type":"text"},{"type":"codeVoice","code":"Container"},{"text":" to expose its content.","type":"text"}],"type":"paragraph"},{"text":"Opening a publication (`ReadiumStreamer`)","anchor":"Opening-a-publication-ReadiumStreamer","type":"heading","level":2},{"inlineContent":[{"text":"To retrieve a ","type":"text"},{"type":"codeVoice","code":"Publication"},{"text":" object from a publication file like an EPUB or audiobook, you can use an ","type":"text"},{"type":"codeVoice","code":"AssetRetriever"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"PublicationOpener"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Instantiate the required components.","let httpClient = DefaultHTTPClient()","let assetRetriever = AssetRetriever(","    httpClient: httpClient",")","let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever,","        pdfFactory: DefaultPDFDocumentFactory()","    )",")","","let url: URL = URL(...)","","\/\/ Retrieve an `Asset` to access the file content.","switch await assetRetriever.retrieve(url: url.anyURL.absoluteURL!) {","case .success(let asset):","    \/\/ Open a `Publication` from the `Asset`.","    switch await publicationOpener.open(asset: asset, allowUserInteraction: true, sender: view) {","    case .success(let publication):","        print(\"Opened \\(publication.metadata.title)\")","","    case .failure(let error):","        \/\/ Failed to access or parse the publication","    }","","case .failure(let error):","    \/\/ Failed to retrieve the asset","}"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"allowUserInteraction"},{"text":" parameter is useful when supporting a DRM like Readium LCP. It indicates if the toolkit can prompt the user for credentials when the publication is protected.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"Open%20Publication.md","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Accessing the metadata of a publication","anchor":"Accessing-the-metadata-of-a-publication","type":"heading","level":2},{"inlineContent":[{"text":"After opening a publication, you may want to read its metadata to insert a new entity into your bookshelf database, for instance. The ","type":"text"},{"type":"codeVoice","code":"publication.metadata"},{"text":" object contains everything you need, including ","type":"text"},{"type":"codeVoice","code":"title"},{"text":", ","type":"text"},{"type":"codeVoice","code":"authors"},{"text":" and the ","type":"text"},{"type":"codeVoice","code":"published"},{"text":" date.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can retrieve the publication cover using ","type":"text"},{"type":"codeVoice","code":"await publication.cover()"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Rendering the publication on the screen (`ReadiumNavigator`)","anchor":"Rendering-the-publication-on-the-screen-ReadiumNavigator","type":"heading","level":2},{"inlineContent":[{"text":"You can use a Readium navigator to present the publication to the user. The ","type":"text"},{"type":"codeVoice","code":"Navigator"},{"text":" renders resources on the screen and offers APIs and user interactions for navigating the contents.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Please refer to the "},{"isActive":true,"type":"reference","overridingTitle":"Navigator guide","overridingTitleInlineContent":[{"text":"Navigator guide","type":"text"}],"identifier":"Navigator\/Navigator.md"},{"type":"text","text":" for more information."}],"type":"paragraph"}],"kind":"content"}],"kind":"article","abstract":[{"text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics.","type":"text"}],"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"],"anchor":"Guides"}],"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started","interfaceLanguage":"swift"},"references":{"doc://Readium/documentation/Readium/Content":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Content","type":"topic","role":"article","url":"\/documentation\/readium\/content","kind":"article","abstract":[],"title":"Extracting the content of a publication"},"https://readium.org/webpub-manifest/":{"title":"Readium Web Publication Manifest","titleInlineContent":[{"type":"text","text":"Readium Web Publication Manifest"}],"identifier":"https:\/\/readium.org\/webpub-manifest\/","url":"https:\/\/readium.org\/webpub-manifest\/","type":"link"},"https://readium.org/webpub-manifest/#24-the-link-object":{"type":"link","titleInlineContent":[{"code":"Link","type":"codeVoice"},{"text":" object","type":"text"}],"url":"https:\/\/readium.org\/webpub-manifest\/#24-the-link-object","identifier":"https:\/\/readium.org\/webpub-manifest\/#24-the-link-object","title":"Link object"},"https://readium.org/architecture/models/locators/":{"title":"Locator object","titleInlineContent":[{"code":"Locator","type":"codeVoice"},{"text":" object","type":"text"}],"identifier":"https:\/\/readium.org\/architecture\/models\/locators\/","url":"https:\/\/readium.org\/architecture\/models\/locators\/","type":"link"},"doc://Readium/documentation/Readium/TTS":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","type":"topic","role":"article","url":"\/documentation\/readium\/tts","kind":"article","title":"Text-to-speech","abstract":[]},"doc://Readium/documentation/Readium/Open-Publication":{"title":"Opening a publication","kind":"article","url":"\/documentation\/readium\/open-publication","role":"article","identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","type":"topic","abstract":[{"type":"text","text":"To open a publication with Readium, you need to instantiate a couple of components: an "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":" and a "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":"."}]},"doc://Readium/documentation/Readium/Readium-LCP":{"type":"topic","title":"Supporting Readium LCP","identifier":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","kind":"article","abstract":[{"type":"text","text":"You can use the Readium Swift toolkit to download and read publications that are protected with the "},{"isActive":true,"type":"reference","identifier":"https:\/\/www.edrlab.org\/readium-lcp\/"},{"type":"text","text":" DRM."}],"url":"\/documentation\/readium\/readium-lcp","role":"article"},"doc://Readium/documentation/Readium/Migration-Guide":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","type":"topic","role":"article","url":"\/documentation\/readium\/migration-guide","kind":"article","title":"Migration Guide","abstract":[{"type":"text","text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file."}]},"Navigator/