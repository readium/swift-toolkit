{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError"},"topicSections":[{"identifiers":["doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError\/cancelled(_:)","doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError\/expired(start:end:)","doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError\/returned(_:)","doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError\/revoked(_:devicesCount:)"],"anchor":"Enumeration-Cases","generated":true,"title":"Enumeration Cases"},{"identifiers":["doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError\/Error-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"abstract":[{"text":"Errors while checking the status of the License, using the Status Document.","type":"text"}],"variants":[{"paths":["\/documentation\/readiumlcp\/statuserror"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/ReadiumLCP"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"StatusError"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"For the case (revoked, returned, cancelled, expired), app should notify the"},{"type":"text","text":" "},{"type":"text","text":"user and stop there. The message to the user must be clear about the status"},{"type":"text","text":" "},{"type":"text","text":"of the license: don’t display “expired” if the status is “revoked”. The"},{"type":"text","text":" "},{"type":"text","text":"date and time corresponding to the new status should be displayed (e.g."},{"type":"text","text":" "},{"type":"text","text":"“The license expired on 01 January 2018”)."}],"type":"paragraph"},{"inlineContent