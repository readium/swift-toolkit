":"text","text":"and whether these are in an accessible format or available in an"},{"type":"text","text":" "},{"type":"text","text":"alternative form, e.g., whether math and chemical formulas are navigable"},{"type":"text","text":" "},{"type":"text","text":"with assistive technologies, or whether extended descriptions are"},{"type":"text","text":" "},{"type":"text","text":"available for information-rich images. In addition, it indicates the"},{"type":"text","text":" "},{"type":"text","text":"presence of videos and if closed captions, open captions, or transcripts"},{"type":"text","text":" "},{"type":"text","text":"for prerecorded audio are available."}],"navigatorTitle":[{"text":"RichContent","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RichContent","kind":"identifier"}],"title":"AccessibilityMetadataDisplayGuide.RichContent"},"doc://Readium/documentation/ReadiumShared/AccessibilityMetadataDisplayGuide/RichContent-swift.struct/init(publication:)":{"kind":"symbol","role":"symbol","title":"init(publication:)","url":"\/documentation\/readiumshared\/accessibilitymetadatadisplayguide\/richcontent-swift.struct\/init(publication:)","abstract":[],"type":"topic","identifier":"doc:\/\/Readium\/documentation\/ReadiumShared\/AccessibilityMetadataDisplayGuide\/RichContent-swift.struct\/init(publication:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"publication","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Publication","kind":"typeIdentifier","preciseIdentifier":"s:13ReadiumShared11PublicationC"},{"text":")","kind":"text"}]}}}