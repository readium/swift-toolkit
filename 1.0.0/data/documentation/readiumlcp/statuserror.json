":"text"},{"text":" ","type":"text"},{"text":"logged in the status document, no such message should appear (certainly not","type":"text"},{"text":" ","type":"text"},{"text":"“The license was registered by 0 devices”).","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Enumeration","externalID":"s:10ReadiumLCP11StatusErrorO","modules":[{"name":"ReadiumLCP"}],"navigatorTitle":[{"text":"StatusError","kind":"identifier"}],"symbolKind":"enum","title":"StatusError","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"StatusError","kind":"identifier"}],"role":"symbol"},"abstract":[{"type":"text","text":"Errors while checking the status of the License, using the Status Document."}],"variants":[{"paths":["\/documentation\/readiumlcp\/statuserror"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/Readium\/s5ErrorP","doc:\/\/Readium\/s8SendableP"]}],"references":{"doc://Readium/documentation/ReadiumLCP":{"kind":"symbol","title":"ReadiumLCP","identifier":"doc:\/\/Readium\/documentation\/ReadiumLCP","role":"collection","url":"\/documentation\/readiumlcp","abstract":[],"type":"topic"},"doc://Readium/documentation/ReadiumLCP/StatusError/returned(_:)":{"title":"StatusError.returned(_:)","kind":"symbol","url":"\/documentation\/readiumlcp\/statuserror\/returned(_:)","identifier":"doc:\/\/Readium\/documentation\/ReadiumLCP\/StatusError\/returned(_:)","type":"topic","role":"symbol","abstract":[{"text":"This license has been returned on the given date.","type":"text"}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"returned","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Date","preciseIdentifier":"s:10Foundation4DateV","kind":"typeIdentifier