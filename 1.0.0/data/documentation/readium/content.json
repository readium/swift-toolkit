{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Readium\/documentation\/Readium\/Content"},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"style":"note","content":[{"inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"The described feature is still experimental and the implementation incomplete.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note"},{"inlineContent":[{"text":"Many high-level features require access to the raw content (text, media, etc.) of a publication, such as:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Text-to-speech"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Accessibility reader"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Basic search","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Full-text search indexing"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Image or audio indexes","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"ContentService","type":"codeVoice"},{"text":" provides a way to iterate through a publication’s content, extracted as semantic elements.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"First, request the publication’s "},{"code":"Content","type":"codeVoice"},{"type":"text","text":", starting from a given "},{"code":"Locator","type":"codeVoice"},{"type":"text","text":". If the locator is missing, the "},{"code":"Content","type":"codeVoice"},{"type":"text","text":" will be extracted from the beginning of the publication."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["guard let content = publication.content(from: startLocator) else {","    \/\/ Abort as the content cannot be extracted","    return","}"]},{"type":"heading","level":2,"anchor":"Extracting-the-raw-text-content","text":"Extracting the raw text content"},{"inlineContent":[{"type":"text","text":"Getting the whole raw text of a publication is such a common use case that a helper is available on "},{"code":"Content","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let wholeText = content.text()"]},{"inlineContent":[{"text":"This is an expensive operation, proceed with caution and cache the result if you need to reuse it.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Iterating through the content","anchor":"Iterating-through-the-content","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The individual "},{"code":"Content","type":"codeVoice"},{"type":"text","text":" elements can be iterated through with a regular "},{"code":"for","type":"codeVoice"},{"type":"text","text":" loop by converting it to a sequence:"}]},{"syntax":"swift","code":["for element in content.sequence() {","    \/\/ Process element","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Alternatively, you can get the whole list of elements with ","type":"text"},{"type":"codeVoice","code":"content.elements()"},{"text":", or use the lower level APIs to iterate the content manually:","type":"text"}]},{"syntax":"swift","code":["let iterator = content.iterator()","while let element = try iterator.next() {","    print(element)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Some ","type":"text"},{"code":"Content","type":"codeVoice"},{"text":" implementations support bidirectional iterations. To iterate backwards, use:","type":"text"}]},{"syntax":"swift","code":["let iterator = content.iterator()","while let element = try iterator.previous() {","    print(element)","}"],"type":"codeListing"},{"type":"heading","text":"Processing the elements","anchor":"Processing-the-elements","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"Content","type":"codeVoice"},{"type":"text","text":" iterator yields "},{"code":"ContentElement","type":"codeVoice"},{"type":"text","text":" objects representing a single semantic portion of the publication, such as a heading, a paragraph or an embedded image."}]},{"type":"paragraph","inlineContent":[{"text":"Every element has a ","type":"text"},{"code":"locator","type":"codeVoice"},{"text":" property targeting it in the publication. You can use the locator, for example, to navigate to the element or to draw a ","type":"text"},{"code":"Decoration","type":"codeVoice"},{"text":" on top of it.","type":"text"}]},{"code":["navigator.go(to: element.locator)"],"syntax":"swift","type":"codeListing"},{"text":"Types of elements","level":3,"type":"heading","anchor":"Types-of-elements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the actual implementation of "},{"code":"ContentElement","type":"codeVoice"},{"type":"text","text":", more properties are available to access the actual data. The toolkit ships with a number of default implementations for common types of elements."}]},{"text":"Embedded media","level":4,"type":"heading","anchor":"Embedded-media"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"EmbeddedContentElement"},{"type":"text","text":" protocol is implemented by any element referencing an external resource. It contains an "},{"type":"codeVoice","code":"embeddedLink"},{"type":"text","text":" property you can use to get the actual content of the resource."}]},{"code":["if let element = element as? EmbeddedContentElement {","    let bytes = try publication","        .get(element.embeddedLink)","        .read().get()","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Here are the default available implementations:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AudioContentElement"},{"type":"text","text":" - audio clips"}]}]},{"content":[{"inlineContent":[{"code":"VideoContentElement","type":"codeVoice"},{"type":"text","text":" - video clips"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ImageContentElement"},{"type":"text","text":" - bitmap images, with the additional property:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"caption: String?","type":"codeVoice"},{"type":"text","text":" - figure caption, when available"}],"type":"paragraph"}]}]}]}]},{"text":"Text","level":4,"type":"heading","anchor":"Text"},{"text":"Textual elements","level":5,"type":"heading","anchor":"Textual-elements"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"TextualContentElement","type":"codeVoice"},{"text":" protocol is implemented by any element which can be represented as human-readable text. This is useful when you want to extract the text content of a publication without caring for each individual type of elements.","type":"text"}]},{"code":["let wholeText = publication.content()","    .elements()","    .compactMap { ($0 as? TextualContentElement)?.text.takeIf { !$0.isEmpty } }","    .joined(separator: \"\\n\")"],"syntax":"swift","type":"codeListing"},{"text":"Text elements","level":5,"type":"heading","anchor":"Text-elements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Actual text elements are instances of "},{"type":"codeVoice","code":"TextContentElement"},{"type":"text","text":", which represent a single block of text such as a heading, a paragraph or a list item. It is comprised of a "},{"type":"codeVoice","code":"role"},{"type":"text","text":" and a list of "},{"type":"codeVoice","code":"segments"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"role","type":"codeVoice"},{"type":"text","text":" is the nature of the text element in the document. For example a heading, body, footnote or a quote. It can be used to reconstruct part of the structure of the original document."}]},{"type":"paragraph","inlineContent":[{"text":"A text element is composed of individual segments with their own ","type":"text"},{"code":"locator","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"attributes","type":"codeVoice"},{"text":". They are useful to associate attributes with a portion of a text element. For example, given the HTML paragraph:","type":"text"}]},{"code":["<p>It is pronounced <span lang=\"fr\">croissant<\/span>.<\/p>"],"syntax":"html","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The following ","type":"text"},{"code":"TextContentElement","type":"codeVoice"},{"text":" will be produced:","type":"text"}]},{"code":["TextContentElement(","    role: .body,","    segments: [","        TextContentElement.Segment(text: \"It is pronounced \"),","        TextContentElement.Segment(text: \"croissant\", attributes: [ContentAttribute(key: .language, value: \"fr\")]),","        TextContentElement.Segment(text: \".\")","    ]",")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If you are not interested in the segment attributes, you can also use ","type":"text"},{"code":"element.text","type":"codeVoice"},{"text":" to get the concatenated raw text.","type":"text"}]},{"text":"Element attributes","level":3,"type":"heading","anchor":"Element-attributes"},{"type":"paragraph","inlineContent":[{"text":"All types of ","type":"text"},{"type":"codeVoice","code":"ContentElement"},{"text":" can have associated attributes. Custom ","type":"text"},{"type":"codeVoice","code":"ContentService"},{"text":" implementations can use this as an extensibility point.","type":"text"}]},{"text":"Use cases","level":2,"type":"heading","anchor":"Use-cases"},{"text":"An index of all images embedded in the publication","level":3,"type":"heading","anchor":"An-index-of-all-images-embedded-in-the-publication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example extracts all the embedded images in the publication and displays them in a SwiftUI list. Clicking on an image jumps to its location in the publication."}]},{"code":["struct ImageIndex: View {","    struct Item: Hashable {","        let locator: Locator","        let text: String?","        let image: UIImage","    }","","    let publication: Publication","    let navigator: Navigator","    @State private var items: [Item] = []","","    init(publication: Publication, navigator: Navigator) {","        self.publication = publication","        self.navigator = navigator","    }","","    var body: some View {","        ScrollView {","            LazyVStack {","                ForEach(items, id: \\.self) { item in","                    VStack() {","                        Image(uiImage: item.image)","                        Text(item.text ?? \"No caption\")","                    }","                    .onTapGesture {","                        navigator.go(to: item.locator)","                    }","                }","            }","        }","        .onAppear {","            items = publication.content()?","                .elements()","                .compactMap { element in","                    guard","                        let element = element as? ImageContentElement,","                        let image = try? publication.get(element.embeddedLink)","                            .read().map(UIImage.init).get()","                    else {","                        return nil","                    }","","                    return Item(","                        locator: element.locator,","                        text: element.caption ?? element.accessibilityLabel,","                        image: image","                    )","                }","                ?? []","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"References","level":2,"type":"heading","anchor":"References"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/readium\/architecture\/pull\/177"}],"type":"paragraph"}]}]}]}],"sections":[],"metadata":{"title":"Extracting the content of a publication","roleHeading":"Article","role":"article"},"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"seeAlsoSections":[{"generated":true,"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility","doc:\/\/Readium\/documentation\/Readium\/Readium-LCP"]}],"references":{"doc://Readium/documentation/Readium/TTS":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","role":"article","title":"Text-to-speech","kind":"article","abstract":[],"type":"topic","url":"\/documentation\/readium\/tts"},"doc://Readium/documentation/Readium/Open-Publication":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" and a ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","role":"article","kind":"article","url":"\/documentation\/readium\/open-publication","title":"Opening a publication"},"doc://Readium/documentation/Readium/NavigatorOverview":{"title":"Navigator Overview","role":"article","url":"\/documentation\/readium\/navigatoroverview","kind":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","abstract":[{"text":"Learn about the architecture, configuration, and usage of the Readium Navigator.","type":"text"}]},"doc://Readium/documentation/Readium/Accessibility":{"kind":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Accessibility","url":"\/documentation\/readium\/accessibility","abstract":[{"text":"Some publications declare their accessibility features and limitations as metadata which broadly mirror the ","type":"text"},{"identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","type":"reference","isActive":true},{"text":" specification.","type":"text"}],"role":"article","title":"Accessibility"},"doc://Readium/documentation/Readium/Migration-Guide":{"title":"Migration Guide","kind":"article","type":"topic","role":"article","url":"\/documentation\/readium\/migration-guide","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}]},"https://github.com/readium/architecture/pull/177":{"titleInlineContent":[{"text":"Content Iterator proposal","type":"text"}],"type":"link","identifier":"https:\/\/github.com\/readium\/architecture\/pull\/177","title":"Content Iterator proposal","url":"https:\/\/github.com\/readium\/architecture\/pull\/177"},"https://www.edrlab.org/readium-lcp/":{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","type":"link","title":"Readium LCP","titleInlineContent":[{"text":"Readium LCP","type":"text"}],"url":"https:\/\/www.edrlab.org\/readium-lcp\/"},"https://www.w3.org/TR/epub-a11y-11":{"titleInlineContent":[{"text":"EPUB Accessibility","type":"text"}],"type":"link","identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","title":"EPUB Accessibility","url":"https:\/\/www.w3.org\/TR\/epub-a11y-11"},"doc://Readium/documentation/Readium":{"url":"\/documentation\/readium","role":"collection","abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"type":"topic","kind":"article","title":"Readium","identifier":"doc:\/\/Readium\/documentation\/Readium"},"doc://Readium/documentation/Readium/Readium-LCP":{"role":"article","type":"topic","title":"Supporting Readium LCP","identifier":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","kind":"article","url":"\/documentation\/readium\/readium-lcp","abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/","type":"reference","isActive":true},{"text":" DRM.","type":"text"}]},"doc://Readium/documentation/Readium/Getting-Started":{"kind":"article","abstract":[{"type":"text","text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics."}],"type":"topic","role":"article","url":"\/documentation\/readium\/getting-started","title":"Getting started","identifier":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started"}}}