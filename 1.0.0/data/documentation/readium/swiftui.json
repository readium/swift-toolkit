{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview"]]},"kind":"article","metadata":{"title":"Integrating the Navigator with SwiftUI","roleHeading":"Article","role":"article"},"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/SwiftUI","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/Readium\/documentation\/Readium\/Navigator","doc:\/\/Readium\/documentation\/Readium\/Preferences","doc:\/\/Readium\/documentation\/Readium\/Input","doc:\/\/Readium\/documentation\/Readium\/EPUB-Fonts"],"anchor":"Essentials","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"SwiftUI wrapper for a Navigator’s `UIViewController`","type":"heading","anchor":"SwiftUI-wrapper-for-a-Navigators-UIViewController"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is a basic example of a "},{"type":"codeVoice","code":"UIViewControllerRepresentable"},{"type":"text","text":" implementation that hosts a Navigator."}]},{"syntax":"swift","code":["\/\/\/ SwiftUI wrapper for the `ReaderViewController`.","struct ReaderViewControllerWrapper: UIViewControllerRepresentable {","    let viewController: ReaderViewController","","    func makeUIViewController(context: Context) -> ReaderViewController {","        viewController","    }","","    func updateUIViewController(_ uiViewController: ReaderViewController, context: Context) {}","}","","\/\/\/ Host view controller for a Readium Navigator.","class ReaderViewController: UIViewController {","","    \/\/\/ View model provided by your application.","    private let viewModel: ReaderViewModel","    ","    \/\/\/ Readium Navigator instance.","    private let navigator: Navigator & UIViewController","","    init(viewModel: ReaderViewModel, navigator: Navigator & UIViewController) {","        self.viewModel = viewModel","        self.navigator = navigator","","        super.init(nibName: nil, bundle: nil)","    }","","    @available(*, unavailable)","    required init?(coder: NSCoder) {","        fatalError(\"init?(coder: NSCoder) not implemented\")","    }","","    override func viewDidLoad() {","        super.viewDidLoad()","","        addChild(navigator)","        navigator.view.frame = view.bounds","        navigator.view.autoresizingMask = [.flexibleWidth, .flexibleHeight]","        view.addSubview(navigator.view)","        navigator.didMove(toParent: self)","    }","","    \/\/\/ Handler for a custom editing action.","    @objc func makeHighlight(_ sender: Any) {","        viewModel.makeHighlight()","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that we could use a "},{"code":"Navigator","type":"codeVoice"},{"type":"text","text":" instance directly, without a parent "},{"code":"ReaderViewController","type":"codeVoice"},{"type":"text","text":". However, a host view controller is necessary if you want to use custom text selection menu items and capture events in the UIKit responder chain. For instance, when configuring your EPUB Navigator with:"}]},{"syntax":"swift","code":["var config = EPUBNavigatorViewController.Configuration()","config.editingActions.append(","    EditingAction(","        title: \"Highlight\",","        action: #selector(makeHighlight)","    )",")","","let navigator = try EPUBNavigatorViewController(","    publication: publication,","    initialLocation: locator,","    config: config,","    ...",")"],"type":"codeListing"},{"level":2,"text":"Embedding the `ReaderViewControllerWrapper` in a SwiftUI view","type":"heading","anchor":"Embedding-the-ReaderViewControllerWrapper-in-a-SwiftUI-view"},{"syntax":"swift","code":["struct ReaderView: View {","    ","    \/\/\/ View model provided by your application.","    @ObservedObject var viewModel: ReaderViewModel","","    let viewControllerWrapper: ReaderViewControllerWrapper","","    var body: some View {","        viewControllerWrapper","            .frame(maxWidth: .infinity, maxHeight: .infinity)","            .ignoresSafeArea(.all)","            .navigationTitle(viewModel.book.title)","            .navigationBarTitleDisplayMode(.inline)","            .navigationBarHidden(viewModel.isFullscreen)","            .statusBarHidden(viewModel.isFullscreen)","    }","}"],"type":"codeListing"},{"level":2,"text":"Assembling the Navigator and SwiftUI objects","type":"heading","anchor":"Assembling-the-Navigator-and-SwiftUI-objects"},{"type":"paragraph","inlineContent":[{"text":"Now, let’s construct an EPUB navigator and assemble the SwiftUI view hierarchy to bring all the pieces together.","type":"text"}]},{"syntax":"swift","code":["var config = EPUBNavigatorViewController.Configuration()","config.editingActions.append(","    EditingAction(","        title: \"Highlight\",","        action: #selector(highlightSelection)","    )",")","","let navigator = try EPUBNavigatorViewController(","    publication: publication,","    initialLocation: locator,","    config: config,","    ...",")","","\/\/ View model provided by your application.","let viewModel = ReaderViewModel()","","let view = ReaderView(","    viewModel: viewModel,","    viewControllerWrapper: ReaderViewControllerWrapper(","        viewController: ReaderViewController(","            viewModel: viewModel,","            navigator: navigator","        )","    )",")"],"type":"codeListing"},{"level":2,"text":"Handling touch and keyboard events","type":"heading","anchor":"Handling-touch-and-keyboard-events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the navigator’s input observer API to handle touch and keyboard events. Avoid using SwiftUI touch modifiers, as they will prevent the user from interacting with the book."}]},{"syntax":"swift","code":["\/\/ Example: Toggle UI visibility when the user taps the navigator.","navigator.addObserver(.tap { [weak viewModel] _ in","    viewModel?.toggleUIVisibility()","    return true","})"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"See the ","type":"text"},{"type":"reference","isActive":true,"identifier":"Input.md"},{"text":" for more details on handling user input.","type":"text"}]}]}],"abstract":[{"text":"The Navigator is built with UIKit and provides ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" implementations. Nevertheless, you can integrate them into a SwiftUI view hierarchy using Apple’s ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/uiviewrepresentable","isActive":true,"type":"reference"},{"text":".","type":"text"}],"sections":[],"references":{"doc://Readium/documentation/Readium/Preferences":{"kind":"article","title":"Configuring the Navigator","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Preferences","role":"article","abstract":[{"type":"text","text":"Take a look at the "},{"type":"reference","isActive":true,"identifier":"..\/Migration%20Guide.md"},{"type":"text","text":" if you are already using the legacy EPUB settings."}],"url":"\/documentation\/readium\/preferences"},"../Migration%20Guide.md":{"title":"migration guide","type":"link","titleInlineContent":[{"text":"migration guide","type":"text"}],"url":"..\/Migration%20Guide.md","identifier":"..\/Migration%20Guide.md"},"Input.md":{"title":"Input guide","type":"link","titleInlineContent":[{"text":"Input guide","type":"text"}],"url":"Input.md","identifier":"Input.md"},"doc://Readium/documentation/Readium/Input":{"title":"Observing user input","role":"article","url":"\/documentation\/readium\/input","kind":"article","abstract":[{"type":"text","text":"In visual publications like EPUB or PDF, users can interact with the "},{"type":"codeVoice","code":"VisualNavigator"},{"type":"text","text":" instance using gestures, a keyboard, a mouse, a pencil, or a trackpad. When the publication does not override user input events, you may want to intercept them to trigger actions in your user interface. For example, you can turn pages or toggle the navigation bar on taps, or open a bookmarks screen when pressing the Command-Shift-D hotkey."}],"type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/Input"},"doc://Readium/documentation/Readium/NavigatorOverview":{"title":"Navigator Overview","role":"article","url":"\/documentation\/readium\/navigatoroverview","kind":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","abstract":[{"text":"Learn about the architecture, configuration, and usage of the Readium Navigator.","type":"text"}]},"doc://Readium/documentation/Readium/EPUB-Fonts":{"kind":"article","abstract":[{"type":"text","text":"Readium allows users to customize the font family used to render a reflowable EPUB, by changing the "},{"type":"reference","isActive":true,"identifier":"Preferences.md"},{"type":"text","text":"."}],"type":"topic","title":"Font families in the EPUB navigator","role":"article","url":"\/documentation\/readium\/epub-fonts","identifier":"doc:\/\/Readium\/documentation\/Readium\/EPUB-Fonts"},"doc://Readium/documentation/Readium/Navigator":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Navigator","url":"\/documentation\/readium\/navigator","title":"Navigator","kind":"article","role":"article","abstract":[{"type":"text","text":"You can use a Readium Navigator to present the publication to the user. The "},{"code":"Navigator","type":"codeVoice"},{"type":"text","text":" renders resources on the screen and offers APIs and user interactions for navigating the contents."}],"type":"topic"},"doc://Readium/documentation/Readium":{"url":"\/documentation\/readium","role":"collection","abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"type":"topic","kind":"article","title":"Readium","identifier":"doc:\/\/Readium\/documentation\/Re