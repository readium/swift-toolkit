{"sections":[],"hierarchy":{"paths":[["doc:\/\/Readium\/documentation\/Readium"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/Readium\/documentation\/Readium\/Getting-Started","doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","doc:\/\/Readium\/documentation\/Readium\/Open-Publication","doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","doc:\/\/Readium\/documentation\/Readium\/Content","doc:\/\/Readium\/documentation\/Readium\/TTS","doc:\/\/Readium\/documentation\/Readium\/Accessibility"],"title":"Guides","generated":true,"anchor":"Guides"}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"article","title":"Supporting Readium LCP","roleHeading":"Article"},"identifier":{"url":"doc:\/\/Readium\/documentation\/Readium\/Readium-LCP","interfaceLanguage":"swift"},"abstract":[{"text":"You can use the Readium Swift toolkit to download and read publications that are protected with the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/www.edrlab.org\/readium-lcp\/"},{"text":" DRM.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"[!IMPORTANT]","type":"text"},{"text":" ","type":"text"},{"text":"To use LCP with the Readium toolkit, you must first obtain the ","type":"text"},{"code":"R2LCPClient","type":"codeVoice"},{"text":" private library by contacting ","type":"text"},{"type":"reference","identifier":"https:\/\/www.edrlab.org\/contact\/","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}],"style":"note"},{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"An LCP publication is protected with a ","type":"text"},{"inlineContent":[{"type":"text","text":"user passphrase"}],"type":"emphasis"},{"text":" and distributed using an LCP License Document (","type":"text"},{"code":".lcpl","type":"codeVoice"},{"text":") .","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The user flow typically goes as follows:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user imports a "},{"type":"codeVoice","code":".lcpl"},{"type":"text","text":" file into your application."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The application uses the Readium toolkit to download the protected publication from the "},{"code":".lcpl","type":"codeVoice"},{"type":"text","text":" file to the userâ€™s bookshelf. The downloaded file can be a "},{"code":".epub","type":"codeVoice"},{"type":"text","text":", "},{"code":".lcpdf","type":"codeVoice"},{"type":"text","text":" (PDF), or "},{"code":".lcpa","type":"codeVoice"},{"type":"text","text":" (audiobook) package."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The user opens the protected publication from the bookshelf.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If the passphrase isnâ€™t already recorded in the ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" internal database, the user will be asked to enter it to unlock the contents.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The publication is decrypted and rendered on the screen."}]}]}]},{"level":2,"anchor":"Setup","text":"Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"To support LCP in your application, you require two components:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" package from the toolkit provides APIs for downloading and decrypting protected publications. Import it as you would any other Readium package, such as ","type":"text"},{"code":"R2Navigator","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The private "},{"code":"R2LCPClient","type":"codeVoice"},{"type":"text","text":" library customized for your application "},{"overridingTitle":"is available from EDRLab","identifier":"https:\/\/www.edrlab.org\/contact\/","overridingTitleInlineContent":[{"text":"is available from EDRLab","type":"text"}],"type":"reference","isActive":true},{"type":"text","text":". They will provide instructions for integrating the "},{"code":"R2LCPClient","type":"codeVoice"},{"type":"text","text":" framework into your application."}],"type":"paragraph"}]}]},{"level":3,"anchor":"File-formats","text":"File formats","type":"heading"},{"inlineContent":[{"text":"Readium LCP specifies new file formats.","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Name","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"File extension"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Media type"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/readium.org\/lcp-specs\/releases\/lcp\/latest.html#32-content-conformance"}]}],[{"type":"paragraph","inlineContent":[{"code":".lcpl","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"application\/vnd.readium.lcp.license.v1.0+json"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/readium.org\/lcp-specs\/notes\/lcp-for-pdf.html"}]}],[{"type":"paragraph","inlineContent":[{"code":".lcpdf","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"application\/pdf+lcp","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/readium.org\/lcp-specs\/notes\/lcp-for-audiobooks.html","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".lcpa"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"application\/audiobook+lcp"}]}]]]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"EPUB files protected by LCP are supported without a special file extension or media type because EPUB accommodates any DRM scheme in its specification.","type":"text"}]}],"style":"note"},{"inlineContent":[{"text":"To support these formats in your application, you need to ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/uniformtypeidentifiers\/defining_file_and_data_types_for_your_app","type":"reference","isActive":true},{"text":" as imported types.","type":"text"}],"type":"paragraph"},{"syntax":"xml","type":"codeListing","code":["<dict>","    <key>UTImportedTypeDeclarations<\/key>","    <array>","        <dict>","            <key>UTTypeIdentifier<\/key>","            <string>org.readium.lcpl<\/string>","            <key>UTTypeConformsTo<\/key>","            <array>","                <string>public.content<\/string>","                <string>public.data<\/string>","                <string>public.json<\/string>","            <\/array>","            <key>UTTypeDescription<\/key>","            <string>LCP License Document<\/string>","            <key>UTTypeTagSpecification<\/key>","            <dict>","                <key>public.filename-extension<\/key>","                <array>","                    <string>lcpl<\/string>","                <\/array>","                <key>public.mime-type<\/key>","                <string>application\/vnd.readium.lcp.license.v1.0+json<\/string>","            <\/dict>","        <\/dict>","        <dict>","            <key>UTTypeIdentifier<\/key>","            <string>org.readium.lcpdf<\/string>","            <key>UTTypeConformsTo<\/key>","            <array>","                <string>public.content<\/string>","                <string>public.data<\/string>","                <string>public.archive<\/string>","                <string>public.zip-archive<\/string>","            <\/array>","            <key>UTTypeDescription<\/key>","            <string>LCP for PDF package<\/string>","            <key>UTTypeTagSpecification<\/key>","            <dict>","                <key>public.filename-extension<\/key>","                <array>","                    <string>lcpdf<\/string>","                <\/array>","                <key>public.mime-type<\/key>","                <string>application\/pdf+lcp<\/string>","            <\/dict>","        <\/dict>","        <dict>","            <key>UTTypeIdentifier<\/key>","            <string>org.readium.lcpa<\/string>","            <key>UTTypeConformsTo<\/key>","            <array>","                <string>public.content<\/string>","                <string>public.data<\/string>","                <string>public.archive<\/string>","                <string>public.zip-archive<\/string>","            <\/array>","            <key>UTTypeDescription<\/key>","            <string>LCP for Audiobooks package<\/string>","            <key>UTTypeTagSpecification<\/key>","            <dict>","                <key>public.filename-extension<\/key>","                <array>","                    <string>lcpa<\/string>","                <\/array>","                <key>public.mime-type<\/key>","                <string>application\/audiobook+lcp<\/string>","            <\/dict>","        <\/dict>","    <\/array>","<\/dict>"]},{"inlineContent":[{"text":"Next, declare the imported types as ","type":"text"},{"identifier":"https:\/\/help.apple.com\/xcode\/mac\/current\/#\/devddd273fdd","type":"reference","isActive":true},{"text":" in the ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" to have your application listed in the â€śOpen withâ€¦â€ť dialogs.","type":"text"}],"type":"paragraph"},{"syntax":"xml","type":"codeListing","code":["<dict>","    <key>CFBundleDocumentTypes<\/key>","    <array>","        <dict>","            <key>CFBundleTypeName<\/key>","            <string>LCP License Document<\/string>","            <key>CFBundleTypeRole<\/key>","            <string>Viewer<\/string>","            <key>LSItemContentTypes<\/key>","            <array>","                <string>org.readium.lcpl<\/string>","            <\/array>","        <\/dict>","        <dict>","            <key>CFBundleTypeName<\/key>","            <string>LCP for PDF package<\/string>","            <key>CFBundleTypeRole<\/key>","            <string>Viewer<\/string>","            <key>LSItemContentTypes<\/key>","            <array>","                <string>org.readium.lcpdf<\/string>","            <\/array>","        <\/dict>","        <dict>","            <key>CFBundleTypeName<\/key>","            <string>LCP for Audiobooks package<\/string>","            <key>CFBundleTypeRole<\/key>","            <string>Viewer<\/string>","            <key>LSItemContentTypes<\/key>","            <array>","                <string>org.readium.lcpa<\/string>","            <\/array>","        <\/dict>","    <\/array>","<\/dict>"]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!TIP]"},{"type":"text","text":" "},{"type":"text","text":"If EPUB is not included in your document types, now is a good time to add it."}]}],"style":"note"},{"level":3,"anchor":"Allow-insecure-HTTP-requests","text":"Allow insecure HTTP requests","type":"heading"},{"inlineContent":[{"type":"text","text":"A file required by the LCP library needs to be downloaded from an insecure HTTP location. You must authorize this download by adding the following to your "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" file:"}],"type":"paragraph"},{"syntax":"xml","type":"codeListing","code":["<key>NSAppTransportSecurity<\/key>","<dict>","    <key>NSExceptionDomains<\/key>","    <dict>","        <key>crl.edrlab.telesec.de<\/key>","        <dict>","            <key>NSExceptionAllowsInsecureHTTPLoads<\/key>","            <true\/>","        <\/dict>","    <\/dict>","<\/dict>"]},{"level":2,"anchor":"Initializing-the-LCPService","text":"Initializing the `LCPService`","type":"heading"},{"inlineContent":[{"code":"ReadiumLCP","type":"codeVoice"},{"text":" offers an ","type":"text"},{"code":"LCPService","type":"codeVoice"},{"text":" object that exposes its API. Since the ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" package is not linked with ","type":"text"},{"code":"R2LCPClient","type":"codeVoice"},{"text":", you need to create your own adapter when setting up the ","type":"text"},{"code":"LCPService","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"LCPService","type":"codeVoice"},{"text":" expects repositories to store the opened licenses and passphrases. ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" provides built-in Keychain-based implementations that store data securely in the iOS\/macOS Keychain. Unlike database-based storage, Keychain data persists across app reinstalls and can optionally be synchronized across the userâ€™s devices via iCloud Keychain.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import R2LCPClient","import ReadiumLCP","","let httpClient = DefaultHTTPClient()","","let assetRetriever = AssetRetriever(","    httpClient: httpClient",")","","let lcpService = LCPService(","    client: LCPClientAdapter(),","    licenseRepository: LCPKeychainLicenseRepository(),","    passphraseRepository: LCPKeychainPassphraseRepository(),","    assetRetriever: assetRetriever,","    httpClient: httpClient",")","","\/\/\/ Facade to the private R2LCPClient.framework.","class LCPClientAdapter: ReadiumLCP.LCPClient {","    func createContext(jsonLicense: String, hashedPassphrase: LCPPassphraseHash, pemCrl: String) throws -> LCPClientContext {","        try R2LCPClient.createContext(jsonLicense: jsonLicense, hashedPassphrase: hashedPassphrase, pemCrl: pemCrl)","    }","","    func decrypt(data: Data, using context: LCPClientContext) -> Data? {","        R2LCPClient.decrypt(data: data, using: context as! DRMContext)","    }","","    func findOneValidPassphrase(jsonLicense: String, hashedPassphrases: [LCPPassphraseHash]) -> LCPPassphraseHash? {","        R2LCPClient.findOneValidPassphrase(jsonLicense: jsonLicense, hashedPassphrases: hashedPassphrases)","    }","}"]},{"inlineContent":[{"type":"text","text":"To disable iCloud synchronization, pass "},{"type":"codeVoice","code":"synchronizable: false"},{"text":" when creating the repositories.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You may also implement your own persistence layer by conforming to "},{"code":"LCPLicenseRepository","type":"codeVoice"},{"type":"text","text":" and "},{"code":"LCPPassphraseRepository","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Acquiring-a-publication-from-a-License-Document-LCPL","text":"Acquiring a publication from a License Document (LCPL)","type":"heading"},{"inlineContent":[{"text":"Users need to import a License Document into your application to download the protected publication (","type":"text"},{"type":"codeVoice","code":".epub"},{"text":", ","type":"text"},{"type":"codeVoice","code":".lcpdf"},{"text":", or ","type":"text"},{"type":"codeVoice","code":".lcpa"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"code":"LCPService","type":"codeVoice"},{"type":"text","text":" offers an API to retrieve the full publication from an LCPL on the filesystem."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let result = await lcpService.acquirePublication(","    from: .file(lcplURL),","    onProgress: { progress in","        switch progress {","            case .indefinite:","                \/\/ Display an activity indicator.","            case .percent(let percent):","                \/\/ Display a progress bar with percent from 0 to 1.","        }","    }",")","","switch result {","case let .success(publication):","    \/\/ Import the `publication.localURL` file as any publication.","case let .failure(error):","    \/\/ Display the error message.","}"]},{"inlineContent":[{"type":"text","text":"After the download is completed, import the "},{"type":"codeVoice","code":"publication.localURL"},{"text":" file into the bookshelf like any other publication file.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Opening-a-publication-protected-with-LCP","text":"Opening a publication protected with LCP","type":"heading"},{"level":3,"anchor":"Initializing-the-PublicationOpener","text":"Initializing the `PublicationOpener`","type":"heading"},{"inlineContent":[{"type":"text","text":"A publication protected with LCP can be opened using the "},{"code":"PublicationOpener","type":"codeVoice"},{"type":"text","text":" component, just like a non-protected publication. However, you must provide a "},{"type":"reference","identifier":"https:\/\/readium.org\/architecture\/proposals\/006-content-protection.html","isActive":true},{"type":"text","text":" implementation when initializing the "},{"code":"PublicationOpener","type":"codeVoice"},{"type":"text","text":" to enable LCP. Luckily, "},{"code":"LCPService","type":"codeVoice"},{"type":"text","text":" has you covered."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let httpClient = DefaultHTTPClient()","","let authentication = LCPDialogAuthentication()","","let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: AssetRetriever(httpClient: httpClient),","        pdfFactory: DefaultPDFDocumentFactory()","    ),","    contentProtections: [","        lcpService.contentProtection(with: authentication)","    ]",")"]},{"inlineContent":[{"type":"text","text":"An LCP package is secured with a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"user passphrase"}]},{"type":"text","text":" for decrypting the content. The "},{"type":"codeVoice","code":"LCPAuthenticating"},{"type":"text","text":" protocol used by "},{"type":"codeVoice","code":"LCPService.contentProtection(with:)"},{"type":"text","text":" provides the passphrase when needed. You can use the default UIKit "},{"type":"codeVoice","code":"LCPDialogAuthentication"},{"type":"text","text":" which displays a pop-up to enter the passphrase, or implement your own method for passphrase retrieval. If your application is built using SwiftUI, "},{"type":"reference","identifier":"#using-the-swiftui-lcp-authentication-dialog","isActive":true}],"type":"paragraph"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"[!NOTE]","type":"text"},{"text":" ","type":"text"},{"text":"The user will be prompted once per passphrase since ","type":"text"},{"code":"ReadiumLCP","type":"codeVoice"},{"text":" stores known passphrases on the device.","type":"text"}],"type":"paragraph"}],"style":"note"},{"level":3,"anchor":"Opening-the-publication","text":"Opening the publication","type":"heading"},{"inlineContent":[{"type":"text","text":"You are now ready to open the publication file with your "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":" instance."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Retrieve an `Asset` to access the file content.","let url = FileURL(path: \"\/path\/to\/lcp-protected-book.epub\", isDirectory: false)","let asset = try await assetRetriever.retrieve(url: url).get()"," ","\/\/ Open a `Publication` from the `Asset`.","let result = await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: hostViewController",")","","switch result {","case .success(let publication):","    \/\/ Import or present the publication.","case .failure(let error):","    \/\/ Present the error.","}"]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"allowUserInteraction"},{"type":"text","text":" and "},{"type":"codeVoice","code":"sender"},{"type":"text","text":" arguments are forwarded to the "},{"type":"codeVoice","code":"LCPAuthenticating"},{"type":"text","text":" implementation when the passphrase is unknown. "},{"type":"codeVoice","code":"LCPDialogAuthentication"},{"type":"text","text":" shows a pop-up only if "},{"type":"codeVoice","code":"allowUserInteraction"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":", using the "},{"type":"codeVoice","code":"sender"},{"type":"text","text":" as the pop-upâ€™s host "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"When importing the publication to the bookshelf, set ","type":"text"},{"type":"codeVoice","code":"allowUserInteraction"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" as you donâ€™t need the passphrase for accessing the publication metadata and cover. If you intend to present the publication using a Navigator, set ","type":"text"},{"type":"codeVoice","code":"allowUserInteraction"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" as decryption will be required.","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[!TIP]"},{"type":"text","text":" "},{"type":"text","text":"To check if an asset is protected with LCP before opening it, you can use "},{"type":"codeVoice","code":"asset.format.conformsTo(.lcp)"},{"type":"text","text":"."}]}],"style":"note"},{"level":3,"anchor":"Using-the-opened-Publication","text":"Using the opened `Publication`","type":"heading"},{"inlineContent":[{"type":"text","text":"After obtaining a "},{"type":"codeVoice","code":"Publication"},{"type":"text","text":" instance, you can access the publicationâ€™s metadata to import it into the userâ€™s bookshelf. The user passphrase is not needed for reading the metadata or cover."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"However, if you want to display the publication with a Navigator, verify it is not restricted. It could be restricted if the user passphrase is unknown or if the license is no longer valid (e.g., expired loan, revoked purchase, etc.)."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["if publication.isRestricted {","    if let error = publication.protectionError as? LCPError {","        \/\/ The user is not allowed to open the publication. You should display the error.","    } else {","        \/\/ We don't have the user passphrase.","        \/\/ You may use `publication` to access its metadata, but not to render its content.","    }","} else {","    \/\/ The publication is not restricted, you may render it with a Navigator component.","}"]},{"level":2,"anchor":"Streaming-an-LCP-protected-package","text":"Streaming an LCP protected package","type":"heading"},{"inlineContent":[{"text":"If the server hosting the LCP protected package supports the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/httpwg.org\/specs\/rfc9110.html#HEAD"},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/httpwg.org\/specs\/rfc7233.html"},{"text":", it is possible to stream directly an LCP protected publication from a License Document (","type":"text"},{"code":".lcpl","type":"codeVoice"},{"text":") file, without downloading the whole publication first.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Simply open the License Document directly using the "},{"type":"codeVoice","code":"PublicationOpener"},{"type":"text","text":". Make sure you provide an "},{"type":"codeVoice","code":"HTTPClient"},{"type":"text","text":" (or an "},{"type":"codeVoice","code":"HTTPResourceFactory"},{"type":"text","text":" for additional customization) to the "},{"type":"codeVoice","code":"AssetRetriever"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Instantiate the required components.","let httpClient = DefaultHTTPClient()","let assetRetriever = AssetRetriever(httpClient: httpClient)","let publicationOpener = PublicationOpener(","    parser: DefaultPublicationParser(","        httpClient: httpClient,","        assetRetriever: assetRetriever","    ),","    contentProtections: [","        lcpService.contentProtection(with: LCPDialogAuthentication()),","    ]",")","","\/\/ Retrieve an `Asset` to access the LCPL content.","let url = FileURL(path: \"\/path\/to\/license.lcpl\", isDirectory: false)","let asset = try await assetRetriever.retrieve(url: url).get()"," ","\/\/ Open a `Publication` from the LCPL `Asset`.","let publication = try await publicationOpener.open(","    asset: asset,","    allowUserInteraction: true,","    sender: hostViewController",").get()","    ","print(\"Opened \\(publication.metadata.title)\")"]},{"level":2,"anchor":"Obtaining-information-on-an-LCP-license","text":"Obtaining information on an LCP license","type":"heading"},{"inlineContent":[{"type":"text","text":"An LCP License Document contains metadata such as its expiration date, the remaining number of characters to copy and the user name. You can access this information using an "},{"type":"codeVoice","code":"LCPLicense"},{"type":"text","text":" object."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"LCPService"},{"type":"text","text":" to retrieve the "},{"type":"codeVoice","code":"LCPLicense"},{"type":"text","text":" instance for a publication."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let result = await lcpService.retrieveLicense(","    from: asset,","    authentication: LCPDialogAuthentication(),","    allowUserInteraction: true,","    sender: hostViewController",")","","switch result {","case .success(let lcpLicense):","    if let user = lcpLicense.license.user.name {","        print(\"The publication was acquired by \\(user)\")","    }","    if let endDate = lcpLicense.license.rights.end {","        print(\"The loan expires on \\(endDate)\")","    }","    if let copyLeft = await lcpLicense.charactersToCopyLeft() {","        print(\"You can copy up to \\(copyLeft) characters remaining.\")","    }","case .failure(let error):","    \/\/ Display the error.","}"]},{"inlineContent":[{"text":"If you have already opened a ","type":"text"},{"type":"codeVoice","code":"Publication"},{"text":" with the ","type":"text"},{"type":"codeVoice","code":"PublicationOpener"},{"text":", you can directly obtain the ","type":"text"},{"type":"codeVoice","code":"LCPLicense"},{"text":" using ","type":"text"},{"type":"codeVoice","code":"publication.lcpLicense"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Managing-a-loan","text":"Managing a loan","type":"heading"},{"inlineContent":[{"type":"text","text":"Readium LCP allows borrowing publications for a specific period. Use the "},{"code":"LCPLicense","type":"codeVoice"},{"type":"text","text":" object to manage a loan and retrieve its end date using "},{"code":"lcpLicense.license.rights.end","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":3,"anchor":"Returning-a-loan","text":"Returning a loan","type":"heading"},{"inlineContent":[{"text":"Some loans can be returned before the end date. You can confirm this by using ","type":"text"},{"code":"lcpLicense.canReturnPublication","type":"codeVoice"},{"text":". To return the publication, execute:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let result = await lcpLicense.returnPublication()","switch result {","case .success:","    \/\/ The publication was returned.","case .failure(let error):","    \/\/ Present the error.","}"]},{"level":3,"anchor":"Renewing-a-loan","text":"Renewing a loan","type":"heading"},{"inlineContent":[{"text":"The loan end date may also be extended. You can confirm this by using ","type":"text"},{"type":"codeVoice","code":"lcpLicense.canRenewLoan"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Readium LCP supports "},{"identifier":"https:\/\/readium.org\/lcp-specs\/releases\/lsd\/latest#35-renewing-a-license","isActive":true,"type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Programmatic: You show your own user interface."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Interactive: You display a web view, and the Readium LSD server manages the renewal for you.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"You need to support both interactions by implementing the ","type":"text"},{"code":"LCPRenewDelegate","type":"codeVoice"},{"text":" protocol. A default implementation is available with ","type":"text"},{"code":"LCPDefaultRenewDelegate","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let result = await lcpLicense.renewLoan(","    with: LCPDefaultRenewDelegate(","        presentingViewController: hostViewController","    )",")","","switch result {","case .success:","    \/\/ The publication was renewed.","case let .failure(error):","    \/\/ Display the error.","}"]},{"level":2,"anchor":"Handling-LCPError","text":"Handling `LCPError`","type":"heading"},{"inlineContent":[{"text":"The APIs may fail with an ","type":"text"},{"code":"LCPError","type":"codeVoice"},{"text":". These errors ","type":"text"},{"inlineContent":[{"type":"text","text":"must"}],"type":"strong"},{"text":" be displayed to the user with a suitable message.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For an example, ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/readium\/swift-toolkit\/blob\/3.0.0\/TestApp\/Sources\/App\/Readium.swift#L221"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Using-the-SwiftUI-LCP-Authentication-dialog","text":"Using the SwiftUI LCP Authentication dialog","type":"heading"},{"inlineContent":[{"text":"If your application is built using SwiftUI, you cannot use ","type":"text"},{"code":"LCPDialogAuthentication","type":"codeVoice"},{"text":" because it requires a UIKit view controller as its host. Instead, use an ","type":"text"},{"code":"LCPObservableAuthentication","type":"codeVoice"},{"text":" combined with our SwiftUI ","type":"text"},{"code":"LCPDialog","type":"codeVoice"},{"text":" presented as a sheet.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@main","struct MyApp: App {","    private let lcpService: LCPService","    private let publicationOpener: PublicationOpener","","    @StateObject private var lcpAuthentication: LCPObservableAuthentication","","    init() {","        \/\/ Create an `LCPObservableAuthentication` which will be used","        \/\/ to initialize the `LCPContentProtection`.","        \/\/","        \/\/ With SwiftUI, it must be stored in a `@StateObject` property","        \/\/ to observe the authentication requests.","        let lcpAuthentication = LCPObservableAuthentication()","        _lcpAuthentication = StateObject(wrappedValue: lcpAuthentication)","","        lcpService = LCPService(...)","","        publicationOpener = PublicationOpener(","            ...,","            contentProtections: [","                lcpService.contentProtection(with: lcpAuthentication)","            ]","        )","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","                \/\/ You can present an `LCPDialog` when the `LCPObservableAuthentication`","                \/\/ `request` property is updated.","                .sheet(item: $lcpAuthentication.request) {","                    LCPDialog(request: $0)","                }","            }","        }","    }","}"]}]}],"references":{"https://readium.org/lcp-specs/releases/lsd/latest#35-renewing-a-license":{"type":"link","titleInlineContent":[{"type":"text","text":"two types of renewal interactions"}],"identifier":"https:\/\/readium.org\/lcp-specs\/releases\/lsd\/latest#35-renewing-a-license","title":"two types of renewal interactions","url":"https:\/\/readium.org\/lcp-specs\/releases\/lsd\/latest#35-renewing-a-license"},"https://readium.org/lcp-specs/releases/lcp/latest.html#32-content-conformance":{"identifier":"https:\/\/readium.org\/lcp-specs\/releases\/lcp\/latest.html#32-content-conformance","titleInlineContent":[{"text":"License Document","type":"text"}],"url":"https:\/\/readium.org\/lcp-specs\/releases\/lcp\/latest.html#32-content-conformance","title":"License Document","type":"link"},"https://readium.org/lcp-specs/notes/lcp-for-pdf.html":{"type":"link","titleInlineContent":[{"type":"text","text":"LCP for PDF package"}],"identifier":"https:\/\/readium.org\/lcp-specs\/notes\/lcp-for-pdf.html","title":"LCP for PDF package","url":"https:\/\/readium.org\/lcp-specs\/notes\/lcp-for-pdf.html"},"doc://Readium/documentation/Readium/Open-Publication":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" and a ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","role":"article","kind":"article","url":"\/documentation\/readium\/open-publication","title":"Opening a publication"},"#using-the-swiftui-lcp-authentication-dialog":{"identifier":"#using-the-swiftui-lcp-authentication-dialog","titleInlineContent":[{"text":"prefer using the new ","type":"text"},{"code":"LCPDialog","type":"codeVoice"}],"url":"#using-the-swiftui-lcp-authentication-dialog","title":"prefer using the new LCPDialog","type":"link"},"https://www.w3.org/TR/epub-a11y-11":{"type":"link","titleInlineContent":[{"type":"text","text":"EPUB Accessibility"}],"identifier":"https:\/\/www.w3.org\/TR\/epub-a11y-11","title":"EPUB Accessibility","url":"https:\/\/www.w3.org\/TR\/epub-a11y-11"},"doc://Readium/documentation/Readium/Content":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Content","role":"article","title":"Extracting the content of a publication","kind":"article","abstract":[],"type":"topic","url":"\/documentation\/readium\/content"},"https://github.com/readium/swift-toolkit/blob/3.0.0/TestApp/Sources/App/Readium.swift#L221":{"identifier":"https:\/\/github.com\/readium\/swift-toolkit\/blob\/3.0.0\/TestApp\/Sources\/App\/Readium.swift#L221","titleInlineContent":[{"text":"take a look at the Test App","type":"text"}],"url":"https:\/\/github.com\/readium\/swift-toolkit\/blob\/3.0.0\/TestApp\/Sources\/App\/Readium.swift#L221","title":"take a look at the Test App","type":"link"},"doc://Readium/documentation/Readium/TTS":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/TTS","role":"article","title":"Text-to-speech","kind":"article","abstract":[],"type":"topic","url":"\/documentation\/readium\/tts"},"doc://Readium/documentation/Readium/Getting-Started":{"kind":"article","abstract":[{"type":"text","text":"The Readium Swift toolkit enables you to develop reading apps for iOS and iPadOS. It provides built-in support for multiple publication formats such as EPUB, PDF, audiobooks, and comics."}],"type":"topic","role":"article","url":"\/documentation\/readium\/getting-started","title":"Getting started","identifier":"doc:\/\/Readium\/documentation\/Readium\/Getting-Started"},"https://readium.org/architecture/proposals/006-content-protection.html":{"type":"link","titleInlineContent":[{"type":"codeVoice","code":"ContentProtection"}],"identifier":"https:\/\/readium.org\/a