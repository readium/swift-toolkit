/#24-the-link-object","type":"link"},"doc://Readium/documentation/Readium":{"url":"\/documentation\/readium","role":"collection","abstract":[{"type":"text","text":"The Readium Swift Toolkit is a toolkit for ebooks, audiobooks, and comics written in Swift & Kotlin."}],"type":"topic","kind":"article","title":"Readium","identifier":"doc:\/\/Readium\/documentation\/Readium"},"doc://Readium/documentation/Readium/Content":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Content","role":"article","title":"Extracting the content of a publication","kind":"article","abstract":[],"type":"topic","url":"\/documentation\/readium\/content"},"doc://Readium/documentation/Readium/Open-Publication":{"identifier":"doc:\/\/Readium\/documentation\/Readium\/Open-Publication","abstract":[{"text":"To open a publication with Readium, you need to instantiate a couple of components: an ","type":"text"},{"code":"AssetRetriever","type":"codeVoice"},{"text":" and a ","type":"text"},{"code":"PublicationOpener","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","role":"article","kind":"article","url":"\/documentation\/readium\/open-publication","title":"Opening a publication"},"doc://Readium/documentation/Readium/Migration-Guide":{"title":"Migration Guide","kind":"article","type":"topic","role":"article","url":"\/documentation\/readium\/migration-guide","identifier":"doc:\/\/Readium\/documentation\/Readium\/Migration-Guide","abstract":[{"text":"All migration steps necessary in reading apps to upgrade to major versions of the Swift Readium toolkit will be documented in this file.","type":"text"}]},"doc://Readium/documentation/Readium/NavigatorOverview":{"title":"Navigator Overview","role":"article","url":"\/documentation\/readium\/navigatoroverview","kind":"article","type":"topic","identifier":"doc:\/\/Readium\/documentation\/Readium\/NavigatorOverview","abstract":[{"text":"Learn about the architecture, configuration, and usage of the Readium Navigator.","type":"text"}]},"https://